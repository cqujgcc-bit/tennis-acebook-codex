@import "/styles/icons.wxss";

page { background: #F2F4F3; }
.page { padding-bottom: 160rpx; }

/* 顶部 banner */
.banner {
  position: relative;
  height: 280rpx;
  background-size: cover;
  background-position: center;
  background-color: #0B3D2E;
}
.banner-mask {
  position: absolute; left: 0; right: 0; top: 0; bottom: 0;
  background: linear-gradient(90deg, rgba(11,61,46,0.85) 0%, rgba(11,61,46,0.35) 55%, rgba(11,61,46,0.15) 100%);
}
.banner-text {
  position: absolute; left: 40rpx; top: 50%; transform: translateY(-50%);
  display: flex; flex-direction: column;
}
.banner-title { font-size: 46rpx; font-weight: 800; color: #fff; letter-spacing: 1rpx; }
.banner-sub { font-size: 26rpx; color: rgba(255,255,255,0.88); margin-top: 12rpx; }

/* 卡片 */
.card {
  background: #fff;
  margin: 24rpx 24rpx 0;
  border-radius: 24rpx;
  padding: 28rpx 28rpx 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
}
.card-head { display: flex; align-items: baseline; margin-bottom: 24rpx; }
.card-title { font-size: 32rpx; font-weight: 700; color: #1A1A1A; }
.card-sub { font-size: 24rpx; color: #9AA0A6; margin-left: 12rpx; }

/* A 标题 */
.title-row {
  display: flex; align-items: center;
  background: #F7F9F8; border-radius: 16rpx; padding: 0 24rpx;
}
.title-input { flex: 1; height: 88rpx; font-size: 30rpx; color: #1A1A1A; }
.title-input::placeholder { color: #B5BBC0; }

/* B 日期胶囊 */
.date-scroll { white-space: nowrap; margin-bottom: 8rpx; }
.date-chip {
  display: inline-flex; flex-direction: column; align-items: center; justify-content: center;
  width: 132rpx; height: 116rpx; margin-right: 16rpx;
  background: #fff; border: 2rpx solid #E3E7E5; border-radius: 18rpx;
  vertical-align: top;
}
.date-chip.active { background: #0B3D2E; border-color: #0B3D2E; }
.date-week { font-size: 24rpx; color: #6B7280; }
.date-day { font-size: 36rpx; font-weight: 700; color: #1A1A1A; margin-top: 4rpx; }
.date-chip.active .date-week { color: #D4FF3F; }
.date-chip.active .date-day { color: #fff; }

/* 时间 */
.time-row {
  display: flex; align-items: center; position: relative;
  margin-top: 24rpx; padding: 16rpx 0;
  border-top: 2rpx solid #F0F2F1;
}
.time-cell { flex: 1; display: flex; align-items: center; justify-content: center; }
.time-label { font-size: 28rpx; color: #6B7280; margin-right: 16rpx; }
.time-val { font-size: 32rpx; font-weight: 600; color: #0B3D2E; }
.time-val.ph { color: #B5BBC0; font-weight: 400; }
.time-divider { width: 2rpx; height: 36rpx; background: #E3E7E5; flex-shrink: 0; }

/* 地点 */
.loc-row {
  display: flex; align-items: center;
  margin-top: 12rpx; padding-top: 24rpx;
  border-top: 2rpx solid #F0F2F1;
}
.loc-pin {
  width: 72rpx; height: 72rpx; border-radius: 50%;
  background: #F0F7E8; display: flex; align-items: center; justify-content: center;
  margin-right: 20rpx; flex-shrink: 0;
}
.loc-text { flex: 1; display: flex; flex-direction: column; }
.loc-name { font-size: 30rpx; font-weight: 600; color: #1A1A1A; }
.loc-name.ph { color: #B5BBC0; font-weight: 400; }
.loc-addr { font-size: 24rpx; color: #9AA0A6; margin-top: 6rpx; }
.loc-btn {
  font-size: 26rpx; color: #0B3D2E; border: 2rpx solid #0B3D2E;
  border-radius: 30rpx; padding: 10rpx 24rpx; flex-shrink: 0;
}

/* 场地号 */
.court-row {
  display: flex; align-items: center;
  margin-top: 12rpx; padding-top: 24rpx;
  border-top: 2rpx solid #F0F2F1;
}
.court-label { width: 180rpx; font-size: 28rpx; color: #4B5563; flex-shrink: 0; }
.court-input {
  flex: 1; height: 72rpx; font-size: 30rpx; color: #1A1A1A;
  background: #F7F9F8; border-radius: 14rpx; padding: 0 24rpx;
}
.court-input::placeholder { color: #B5BBC0; }

/* C/D 设置行 */
.setting-row { display: flex; align-items: flex-start; margin-bottom: 24rpx; }
.setting-row:last-child { margin-bottom: 0; }
.setting-label { width: 180rpx; font-size: 28rpx; color: #4B5563; padding-top: 12rpx; flex-shrink: 0; }
.pill-group { flex: 1; display: flex; flex-wrap: wrap; }
.pill {
  padding: 12rpx 28rpx; margin: 0 16rpx 16rpx 0;
  background: #fff; border: 2rpx solid #E3E7E5; border-radius: 30rpx;
  font-size: 26rpx; color: #4B5563;
}
.pill.active { background: #0B3D2E; border-color: #0B3D2E; color: #D4FF3F; font-weight: 600; }

/* 步进器 */
.stepper { display: flex; align-items: center; }
.step-btn {
  width: 60rpx; height: 60rpx; line-height: 56rpx; text-align: center;
  border: 2rpx solid #E3E7E5; border-radius: 12rpx; font-size: 40rpx; color: #0B3D2E;
}
.step-val { width: 100rpx; text-align: center; font-size: 32rpx; font-weight: 700; color: #1A1A1A; }

/* 水平下拉 */
.level-row { align-items: center; }
.level-row .setting-label { padding-top: 0; }
.level-picker { flex: 1; }
.level-val {
  display: inline-block; padding: 14rpx 28rpx;
  background: #F7F9F8; border-radius: 14rpx;
  font-size: 28rpx; color: #0B3D2E; font-weight: 600;
}

.switch-row { align-items: center; }
.switch-row .setting-label { padding-top: 0; flex: 1; }

/* 费用 */
.fee-row { display: flex; align-items: center; margin-bottom: 16rpx; }
.fee-input-wrap {
  flex: 1; display: flex; align-items: center;
  background: #F7F9F8; border-radius: 16rpx; padding: 0 24rpx;
}
.fee-prefix { font-size: 32rpx; font-weight: 700; color: #FF5A4D; margin-right: 8rpx; }
.fee-input { flex: 1; height: 80rpx; font-size: 36rpx; font-weight: 700; color: #FF5A4D; }
.fee-unit { font-size: 26rpx; color: #9AA0A6; }
.per-line {
  display: flex; align-items: center; justify-content: space-between;
  background: #F0F7E8; border-radius: 14rpx; padding: 18rpx 24rpx; margin-bottom: 16rpx;
}
.per-label { font-size: 26rpx; color: #4B5563; }
.per-val { font-size: 34rpx; font-weight: 800; color: #FF5A4D; }
.fee-hint { font-size: 22rpx; color: #9AA0A6; line-height: 1.6; margin-bottom: 24rpx; }

/* 底部悬浮条 */
.submit-bar {
  position: fixed; left: 0; right: 0; bottom: 0;
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: #fff; box-shadow: 0 -4rpx 24rpx rgba(0,0,0,0.06);
}
.submit-left { display: flex; flex-direction: column; }
.submit-est-label { font-size: 22rpx; color: #9AA0A6; }
.submit-est-val { font-size: 36rpx; font-weight: 700; color: #FF5A4D; }
.submit-btn {
  display: inline-flex; align-items: center; justify-content: center;
  height: 88rpx; min-width: 200rpx; padding: 0 56rpx; border-radius: 44rpx;
  background: #0B3D2E; color: #fff; font-size: 32rpx; font-weight: 700;
  line-height: 88rpx; margin: 0;
}
.submit-btn::after { border: none; }
.submit-btn.disabled { opacity: 0.6; }


.icon { display: inline-block; }
.ab-icon-edit { width: 36rpx; height: 36rpx; flex-shrink: 0; }
.ab-icon-pin-green { width: 40rpx; height: 40rpx; }
.bottom-pad { height: 20rpx; }

/* 时间滚动选择器弹层 */
.tp-mask {
  position: fixed; left: 0; right: 0; top: 0; bottom: 0;
  background: rgba(0,0,0,0.45); z-index: 100;
  display: flex; align-items: flex-end;
}
.tp-panel {
  width: 100%; background: #fff;
  border-radius: 28rpx 28rpx 0 0; overflow: hidden;
  padding-bottom: env(safe-area-inset-bottom);
}
.tp-head {
  display: flex; align-items: center; justify-content: space-between;
  padding: 28rpx 32rpx; border-bottom: 2rpx solid #F0F2F1;
}
.tp-cancel { font-size: 30rpx; color: #9AA0A6; }
.tp-title { font-size: 30rpx; font-weight: 700; color: #1A1A1A; }
.tp-ok { font-size: 30rpx; color: #0B3D2E; font-weight: 700; }
.tp-view { height: 440rpx; }
.tp-item { line-height: 80rpx; text-align: center; font-size: 34rpx; color: #1A1A1A; }
