.page { min-height: 100vh; background: #f5f6f7; padding-bottom: 160rpx; }

.hero { background: linear-gradient(135deg, #0B3D2E 0%, #14503C 100%); color: #fff; padding: 56rpx 40rpx 44rpx; }
.hero-tip { font-size: 24rpx; opacity: 0.85; }
.hero-title { font-size: 44rpx; font-weight: 700; margin-top: 14rpx; }
.hero-from { font-size: 24rpx; opacity: 0.8; margin-top: 16rpx; }

.card { margin: 24rpx; background: #fff; border-radius: 20rpx; padding: 12rpx 28rpx; }
.row { display: flex; align-items: center; padding: 22rpx 0; border-top: 1rpx solid #f2f2f2; }
.row:first-child { border-top: none; }
.k { width: 120rpx; font-size: 26rpx; color: #999; }
.v { flex: 1; font-size: 28rpx; color: #222; }
.v.price { color: #C0392B; font-weight: 600; }

.note { margin: 0 24rpx; font-size: 24rpx; color: #888; line-height: 1.6; padding: 8rpx 4rpx; }

.bottom { position: fixed; left: 0; right: 0; bottom: 0; background: #fff; padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom)); box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.05); }
.btn { background: #0B3D2E; color: #fff; border-radius: 44rpx; font-size: 30rpx; font-weight: 600; padding: 18rpx 0; }

.state { display: flex; flex-direction: column; align-items: center; justify-content: center; padding-top: 200rpx; }
.state-icon { font-size: 96rpx; }
.state-title { font-size: 34rpx; font-weight: 600; color: #222; margin-top: 24rpx; }
.state-sub { font-size: 26rpx; color: #999; margin-top: 12rpx; }
