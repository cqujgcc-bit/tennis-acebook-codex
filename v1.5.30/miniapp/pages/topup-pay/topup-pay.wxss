.page { padding: 40rpx 24rpx 160rpx; background: #f5f7f6; min-height: 100vh; }
.amount-card { background: linear-gradient(135deg, #0B3D2E, #14543d); border-radius: 24rpx; padding: 60rpx 32rpx; text-align: center; margin-bottom: 28rpx; }
.amt-label { display: block; color: #D4FF3F; font-size: 26rpx; margin-bottom: 16rpx; }
.amt-value { display: block; color: #fff; font-size: 80rpx; font-weight: 800; letter-spacing: 1rpx; }
.amt-match { display: block; color: rgba(255,255,255,0.7); font-size: 26rpx; margin-top: 18rpx; }
.reason-card { background: #fff; border-radius: 20rpx; padding: 32rpx 28rpx; box-shadow: 0 2rpx 12rpx rgba(11,61,46,0.04); }
.reason-title { font-size: 28rpx; font-weight: 600; color: #0B3D2E; margin-bottom: 16rpx; }
.reason-text { font-size: 26rpx; color: #666; line-height: 1.7; margin-bottom: 12rpx; }
.hl { color: #0B3D2E; font-weight: 600; }
.footer { position: fixed; left: 0; right: 0; bottom: 0; padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom)); background: #fff; box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.04); }
.btn-primary { background: #0B3D2E; color: #D4FF3F; border-radius: 999rpx; font-size: 30rpx; font-weight: 600; height: 88rpx; line-height: 88rpx; }
.ok { display: flex; flex-direction: column; align-items: center; padding-top: 240rpx; }
.ok-icon { width: 120rpx; height: 120rpx; line-height: 120rpx; text-align: center; border-radius: 50%; background: #0B3D2E; color: #D4FF3F; font-size: 64rpx; margin-bottom: 28rpx; }
.ok-text { font-size: 32rpx; color: #0B3D2E; font-weight: 600; }
.loading { text-align: center; color: #8a948f; padding-top: 200rpx; font-size: 28rpx; }
