.page { min-height: 100vh; background: #f5f6f8; padding: 20rpx 20rpx 160rpx; box-sizing: border-box; }
.loading { text-align: center; color: #999; padding: 80rpx 0; }
.empty { display: flex; flex-direction: column; align-items: center; padding: 140rpx 0; }
.empty-img { width: 200rpx; height: 200rpx; opacity: .6; }
.empty-text { color: #999; margin-top: 24rpx; font-size: 28rpx; }

.card { background: #fff; border-radius: 20rpx; padding: 28rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,.04); }
.card-head { display: flex; justify-content: space-between; align-items: flex-start; }
.title { font-size: 32rpx; font-weight: 600; color: #1a1a1a; flex: 1; margin-right: 16rpx; }
.tags { display: flex; flex-shrink: 0; }
.tag { font-size: 22rpx; padding: 4rpx 14rpx; border-radius: 8rpx; margin-left: 10rpx; }
.tag-free { background: #e8f5e9; color: #43a047; }
.tag-aa { background: #fff3e0; color: #fb8c00; }
.tag-settle { background: #e3f2fd; color: #1e88e5; }

.meta { margin-top: 18rpx; }
.meta-line { display: block; font-size: 26rpx; color: #666; line-height: 1.7; }
.desc { margin-top: 14rpx; font-size: 26rpx; color: #888; line-height: 1.6; }

.signup-avatars { display: flex; margin-top: 18rpx; }
.av { width: 56rpx; height: 56rpx; border-radius: 50%; margin-right: -12rpx; border: 2rpx solid #fff; background: #eee; }

.actions { display: flex; margin-top: 24rpx; }
.btn { font-size: 28rpx; padding: 0 30rpx; height: 68rpx; line-height: 68rpx; border-radius: 999rpx; margin-left: 16rpx; }
.btn::after { border: none; }
.btn:first-child { margin-left: 0; }
.btn-primary { background: #1aad19; color: #fff; }
.btn-ghost { background: #f2f3f5; color: #555; }
.btn-warn { background: #fb8c00; color: #fff; }
.btn-del { background: #FFF0F0; color: #E5392E; border: 2rpx solid #FFCDD2; }
.btn-del:active { background: #FFEBEE; }

.fab { position: fixed; left: 50%; transform: translateX(-50%); bottom: 48rpx; background: #1aad19; color: #fff; font-size: 30rpx; padding: 0 60rpx; height: 88rpx; line-height: 88rpx; border-radius: 999rpx; box-shadow: 0 6rpx 20rpx rgba(26,173,25,.4); }

/* ── v1.5.32 新增样式 ── */

/* 分区标签 */
.section-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A2420;
  padding: 20rpx 12rpx 14rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.section-open { color: #0B3D2E; }
.history-arrow { font-size: 24rpx; color: #8A968F; font-weight: 400; }

/* 报名墙（头像+名字） */
.signup-wall {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
  padding: 12rpx 0;
}
.sw-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  min-width: 64rpx;
}
.sw-av-wrap {
  position: relative;
  width: 56rpx; height: 56rpx;
}
.sw-av {
  width: 56rpx; height: 56rpx;
  border-radius: 50%;
  background: #F1F4F2;
  border: 2rpx solid #fff;
}
.sw-crown {
  position: absolute;
  top: -10rpx; right: -8rpx;
  font-size: 22rpx;
}
.sw-name {
  font-size: 22rpx;
  color: #5A6863;
  max-width: 64rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.sw-me { color: #0B3D2E; font-weight: 700; }
.sw-badge {
  font-size: 18rpx;
  background: #0B3D2E;
  color: #D4FF3F;
  padding: 1rpx 10rpx;
  border-radius: 999rpx;
  line-height: 1.6;
  margin-top: -2rpx;
}
.sw-more .sw-av-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F1F4F2;
  border-radius: 50%;
  width: 56rpx; height: 56rpx;
}
.sw-more-text {
  font-size: 24rpx;
  color: #8A968F;
  font-weight: 600;
}

/* 无人报名占位文字 */
.signup-empty {
  font-size: 24rpx;
  color: #B0B8B2;
  margin-top: 14rpx;
  padding: 4rpx 0;
}

/* 历史活动卡片弱化 */
.card-history { opacity: 0.7; }
.history-section { margin-bottom: 20rpx; }


/* ── v1.5.34 已取消活动样式 ── */
.card-cancelled { opacity: 0.6; filter: grayscale(0.5); }
.title-cancelled { text-decoration: line-through; color: #999 !important; }
.tag-cancelled { background: #ffebee; color: #e53935; }
