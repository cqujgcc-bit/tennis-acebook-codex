<view class="page">
  <view class="card">
    <view class="field">
      <text class="label">平台名称</text>
      <input class="input" placeholder="如：i深体" value="{{form.name}}" bindinput="onField" data-key="name" maxlength="100" />
    </view>
    <view class="field">
      <text class="label">一句话说明</text>
      <input class="input" placeholder="如：深圳市体育场馆预约" value="{{form.description}}" bindinput="onField" data-key="description" maxlength="200" />
    </view>
    <view class="field">
      <text class="label">图标 Emoji</text>
      <input class="input" placeholder="🎾" value="{{form.emoji}}" bindinput="onField" data-key="emoji" maxlength="8" />
    </view>
    <view class="field">
      <text class="label">目标小程序 AppID</text>
      <input class="input" placeholder="wx 开头的 18 位 appid" value="{{form.appId}}" bindinput="onField" data-key="appId" maxlength="32" />
    </view>
    <view class="field">
      <text class="label">业务标识 appKey（选填）</text>
      <input class="input" placeholder="留空将自动生成" value="{{form.appKey}}" bindinput="onField" data-key="appKey" maxlength="64" />
    </view>
  </view>

  <button class="submit-btn" loading="{{submitting}}" bindtap="onSubmit">保存</button>
  <view class="tip">AppID 必须为已在微信后台「关联小程序」名单内的目标小程序，否则用户端无法跳转。</view>
</view>
