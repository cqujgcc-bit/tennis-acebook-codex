<view class="page">
  <view class="header">
    <view class="user-row">
      <!-- 头像：登录后可点击更换（chooseAvatar） -->
      <block wx:if="{{isLogin}}">
        <button class="avatar-btn-wrap" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <image wx:if="{{user.avatar}}" class="avatar-lg avatar-img" src="{{user.avatar}}" mode="aspectFill"></image>
          <view wx:else class="avatar-lg">{{user.nickname[0]}}</view>
          <view class="avatar-edit-badge">⊕</view>
        </button>
      </block>
      <view wx:else class="avatar-lg">{{user.nickname[0]}}</view>

      <view class="user-info" bindtap="onEditProfile">
        <view class="nickname">{{user.nickname}}<text wx:if="{{user.genderIcon}}" class="gender-icon {{user.gender}}">{{user.genderIcon}}</text></view>
        <view class="user-sub">{{user.level ? 'NTRP ' + user.level : '未设置水平'}}{{user.city ? ' · ' + user.city : ''}}</view>
        <view class="user-bio">{{isLogin ? '点击编辑资料' : '点击登录'}}</view>
      </view>
    </view>
    <view class="stats">
      <view class="stat-item">
        <text class="stat-num">{{user.gamesCount}}</text>
        <text class="stat-label">参与球局</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{user.circlesCount}}</text>
        <text class="stat-label">加入圈子</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{user.hoursCount}}</text>
        <text class="stat-label">运动时长</text>
      </view>
    </view>
  </view>

  <view class="menu-group">
    <view class="menu-item" bindtap="onNotifications">
      <text class="menu-ico">🔔</text><text class="menu-text">消息中心</text>
      <view wx:if="{{unreadCount > 0}}" class="menu-badge">{{unreadCount > 99 ? '99+' : unreadCount}}</view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onMenu" data-name="我的球局">
      <text class="menu-ico">🎾</text><text class="menu-text">我的球局</text><text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onWallet">
      <text class="menu-ico">💰</text><text class="menu-text">我的钱包</text><text class="menu-tip">场地费结算·零抽成</text><text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onMenu" data-name="课时包">
      <text class="menu-ico">🎫</text><text class="menu-text">我的课时包</text><text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onCredit">
      <text class="menu-ico">⭐</text><text class="menu-text">我的信用分</text><text class="menu-val">{{user.creditScore}}</text><text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-group">
    <view class="menu-item" bindtap="onBookCourt">
      <text class="menu-ico">🏟</text><text class="menu-text">预约场地</text><text class="menu-tip">跳转合作小程序</text><text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onMenu" data-name="成为教练">
      <text class="menu-ico">🧑‍🏫</text><text class="menu-text">成为教练</text><text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-group" wx:if="{{isAdmin}}">
    <view class="menu-item" bindtap="onAdmin">
      <text class="menu-ico">⚙️</text><text class="menu-text">管理后台</text><text class="menu-tip">超级管理员</text><text class="menu-arrow">›</text>
    </view>
  </view>
  <view class="menu-group" wx:elif="{{isLogin}}">
    <view class="menu-item" bindtap="onClaimAdmin">
      <text class="menu-ico">🔑</text><text class="menu-text">授权码激活管理员</text><text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-group">
    <view class="menu-item" bindtap="onMenu" data-name="意见反馈">
      <text class="menu-ico">📝</text><text class="menu-text">意见反馈</text><text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onMenu" data-name="关于">
      <text class="menu-ico">ℹ️</text><text class="menu-text">关于 AceBook</text><text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="logout" bindtap="onLogout">退出登录</view>
</view>
