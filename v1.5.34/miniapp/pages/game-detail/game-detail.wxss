.page {
  padding-bottom: 160rpx;
}

.hero {
  background-color: #0B3D2E;
  padding: 40rpx 32rpx 48rpx;
  color: #fff;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 700;
}

.hero-circle {
  display: inline-block;
  margin-top: 16rpx;
  font-size: 22rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
}

.hero-status {
  margin-top: 16rpx;
  font-size: 26rpx;
  opacity: 0.9;
}

.info-card {
  background: #fff;
  margin: -24rpx 32rpx 0;
  border-radius: 24rpx;
  padding: 28rpx;
  position: relative;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.info-row {
  display: flex;
  padding: 14rpx 0;
}

.info-label {
  width: 100rpx;
  color: #999;
  font-size: 28rpx;
}

.info-val {
  overflow-wrap: break-word;
  word-break: break-word;
  flex: 1;
  color: #333;
  font-size: 28rpx;
}

.info-val.price {
  color: #e89c2c;
  font-weight: 700;
}

.section {
  background: #fff;
  margin: 24rpx 32rpx 0;
  border-radius: 24rpx;
  padding: 28rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
}

.players-grid {
  display: flex;
  flex-wrap: wrap;
}

.player-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}

.player-name {
  font-size: 24rpx;
  color: #333;
  margin-top: 10rpx;
}

.player-level {
  font-size: 22rpx;
  color: #0B3D2E;
}

.empty-slot .player-name {
  color: #bbb;
}

.avatar-wrap { position: relative; width: 96rpx; height: 96rpx; }
.player-item .avatar {
  width: 96rpx; height: 96rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  background: rgba(11,61,46,0.1); color: #0B3D2E;
  font-size: 40rpx; font-weight: 700;
}
.avatar-photo { object-fit: cover; }
.host-badge {
  position: absolute; left: 50%; transform: translateX(-50%);
  bottom: -8rpx;
  background: #D4FF3F; color: #0B3D2E;
  font-size: 18rpx; font-weight: 700;
  padding: 2rpx 12rpx; border-radius: 999rpx;
  white-space: nowrap;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.12);
}

.avatar-empty {
  background: #f0f0f0;
  color: #bbb;
}

.chat-box {
  background: #f7f9f8;
  border-radius: 16rpx;
  padding: 24rpx;
  min-height: 200rpx;
}

.msg {
  display: flex;
  margin-bottom: 24rpx;
  align-items: flex-start;
}

.msg-self {
  flex-direction: row-reverse;
}

.msg-bubble {
  max-width: 70%;
  margin: 0 16rpx;
  display: flex;
  flex-direction: column;
}

.msg-name {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 6rpx;
}

.msg-text {
  background: #fff;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #333;
}

.msg-self .msg-text {
  background: #0B3D2E;
  color: #fff;
}

.chat-input-row {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
}

.chat-input {
  flex: 1;
  background: #f0f0f0;
  border-radius: 999rpx;
  height: 72rpx;
  padding: 0 28rpx;
  font-size: 26rpx;
}

.chat-send {
  margin-left: 16rpx;
  color: #bbb;
  font-size: 28rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  padding: 20rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.bar-price {
  font-size: 40rpx;
  color: #e89c2c;
  font-weight: 700;
}

.bar-price-unit {
  font-size: 24rpx;
  color: #999;
}

.bar-btn {
  background: #0B3D2E;
  color: #fff;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
  padding: 0 56rpx;
  height: 84rpx;
  line-height: 84rpx;
}
.bar-btn::after {
  border: none;
}

.bar-share {
  background: #EAF3EE;
  color: #0B3D2E;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
  padding: 0 36rpx;
  height: 84rpx;
  line-height: 84rpx;
  margin-left: auto;
  margin-right: 16rpx;
}
.bar-share::after { border: none; }

.bar-btn-disabled {
  background: #ccc;
  color: #fff;
}

/* 去支付（报名未付）—— 醒目橙色 */
.bar-btn-pay {
  background: #e89c2c;
  color: #fff;
}

/* 已报名/已支付—— 成功态，不可点 */
.bar-btn-joined {
  background: #EAF3EE;
  color: #0B3D2E;
  border: 2rpx solid #0B3D2E;
}

/* 费用说明小字 */
.fee-tip {
  overflow-wrap: break-word;
  word-break: break-word;
  font-size: 22rpx;
  color: #b8862f;
  line-height: 1.5;
}

/* 局内群聊入口 */
.chat-entry {
  display: flex; align-items: center; justify-content: space-between;
  margin: 24rpx 32rpx 0; padding: 28rpx;
  background: linear-gradient(135deg, #0B3D2E 0%, #14503C 100%);
  border-radius: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(11,61,46,0.18);
}
.chat-entry-left { display: flex; align-items: center; }
.chat-entry-icon {
  width: 76rpx; height: 76rpx; border-radius: 20rpx;
  background: rgba(212,255,63,0.18);
  display: flex; align-items: center; justify-content: center;
  font-size: 40rpx; margin-right: 22rpx;
}
.chat-entry-text { display: flex; flex-direction: column; }
.chat-entry-title { font-size: 30rpx; font-weight: 700; color: #fff; }
.chat-entry-sub { font-size: 23rpx; color: rgba(255,255,255,0.7); margin-top: 8rpx; }
.chat-entry-arrow { font-size: 44rpx; color: #D4FF3F; }

/* 发起人确认完成提示 */
.settle-tip {
  margin: 24rpx 32rpx 0;
  padding: 22rpx 26rpx;
  background: #f0f9f3;
  border: 1rpx solid #cdeBD9;
  border-radius: 18rpx;
  font-size: 24rpx;
  color: #0B3D2E;
  line-height: 1.6;
}

/* 一键导航按钮 */
.nav-btn { color: #0B3D2E; font-size: 26rpx; font-weight: 600; padding-left: 16rpx; }

/* 候补头像 */
.avatar-wait { background: #E8B04B !important; color: #fff !important; }
.wait-badge { position: absolute; right: -6rpx; top: -6rpx; min-width: 30rpx; height: 30rpx; line-height: 30rpx; text-align: center; background: #E8B04B; color: #fff; font-size: 20rpx; border-radius: 15rpx; padding: 0 6rpx; }

/* 退出/转让入口 */
.leave-entry { display: flex; align-items: center; justify-content: space-between; margin: 24rpx 32rpx 0; padding: 26rpx 28rpx; background: #fff; border-radius: 16rpx; }
.leave-entry-text { font-size: 28rpx; color: #C0392B; }
.leave-entry-arrow { color: #ccc; font-size: 32rpx; }

.cancel-entry { display: flex; align-items: center; justify-content: space-between; margin: 24rpx 32rpx 0; padding: 26rpx 28rpx; background: #fff; border-radius: 16rpx; border: 1rpx solid #F0D0CB; }
.cancel-entry-text { font-size: 28rpx; color: #C0392B; }
.cancel-entry-arrow { color: #ccc; font-size: 32rpx; }

/* 已取消横幅 */
.cancelled-banner { display: flex; align-items: flex-start; margin: 24rpx 32rpx 0; padding: 24rpx 28rpx; background: #FDECEA; border: 1rpx solid #F5C6C0; border-radius: 16rpx; }
.cancelled-banner-icon { font-size: 32rpx; margin-right: 14rpx; line-height: 40rpx; }
.cancelled-banner-text { flex: 1; font-size: 26rpx; color: #C0392B; line-height: 40rpx; }

/* 候补按钮 */
.bar-btn-wait { background: #E8B04B; color: #fff; }

/* 候补名单列表（含发起人同意按钮） */
.waitlist-list { display: flex; flex-direction: column; }
.waitlist-row { display: flex; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid #F0F2F0; }
.waitlist-row:last-child { border-bottom: none; }
.waitlist-row .avatar-wrap { position: relative; width: 80rpx; height: 80rpx; flex-shrink: 0; }
.waitlist-row .avatar { width: 80rpx; height: 80rpx; border-radius: 50%; }
.waitlist-info { flex: 1; display: flex; flex-direction: column; margin-left: 20rpx; }
.waitlist-info .player-name { font-size: 28rpx; color: #1A1A1A; font-weight: 600; }
.waitlist-info .player-level { font-size: 22rpx; color: #0B3D2E; margin-top: 4rpx; }
.approve-btn { flex-shrink: 0; padding: 12rpx 28rpx; background: #0B3D2E; color: #D4FF3F; font-size: 26rpx; font-weight: 600; border-radius: 30rpx; }
.approve-btn:active { opacity: 0.85; }
.waitlist-rule { margin-top: 20rpx; padding: 18rpx 22rpx; background: #F5F8F5; border-radius: 12rpx; font-size: 22rpx; color: #6B7C72; line-height: 1.6; }

.bar-cancel-replace {
  background: #F2F2F2;
  color: #666;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
  padding: 0 36rpx;
  height: 84rpx;
  line-height: 84rpx;
  margin-right: 16rpx;
}

/* V6 编辑球局入口 */
.edit-entry { display: flex; align-items: center; justify-content: space-between; margin: 24rpx 32rpx 0; padding: 26rpx 28rpx; background: #fff; border-radius: 16rpx; }
.edit-entry-text { color: #0B3D2E; font-size: 28rpx; font-weight: 500; }
.edit-entry-arrow { color: #ccc; font-size: 32rpx; }

/* V6 待补缴入口 */
.topup-entry { display: flex; align-items: center; justify-content: space-between; margin: 24rpx 32rpx 0; padding: 24rpx 28rpx; background: linear-gradient(135deg, #fff7e6, #fff); border: 1rpx solid #ffe0a3; border-radius: 16rpx; }
.topup-entry-left { display: flex; flex-direction: column; }
.topup-entry-title { color: #e08a00; font-size: 30rpx; font-weight: 700; }
.topup-entry-sub { color: #b58a4a; font-size: 23rpx; margin-top: 6rpx; }
.topup-entry-arrow { color: #fff; background: #e08a00; padding: 12rpx 24rpx; border-radius: 999rpx; font-size: 26rpx; font-weight: 600; }

/* ============================================================
   v1.5.28 UI 运动风尚升级
   详情页：计分板感增强、费用说明断行、信息页卡片
   ============================================================ */

/* —— Hero 区计分板感增强 —— */
.hero {
  position: relative;
  overflow: hidden;
}
.hero::before {
  content: '';
  position: absolute;
  right: -80rpx;
  top: -80rpx;
  width: 360rpx;
  height: 360rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(212,255,63,0.10) 0%, rgba(212,255,63,0) 70%);
  pointer-events: none;
}
.hero-title {
  position: relative;
  z-index: 1;
}
.hero-circle {
  position: relative;
  z-index: 1;
}
.hero-status {
  position: relative;
  z-index: 1;
}

/* —— 信息卡片入场 —— */
.info-card {
  animation: ab-card-enter 0.5s ease-out 0.1s both;
}

/* —— 费用说明断行保证 —— */
.fee-tip {
  overflow-wrap: break-word;
  word-break: break-word;
  white-space: pre-line;
}

/* —— 局内群聊入口增强 —— */
.chat-entry {
  animation: ab-card-enter 0.5s ease-out 0.2s both;
}

/* —— 玩家网格增强 —— */
.player-item {
  transition: transform 0.15s ease;
}
.player-item:active {
  transform: scale(0.94);
}

/* —— 底部栏入场 —— */
.bottom-bar {
  animation: ab-card-enter 0.4s ease-out 0.15s both;
}
