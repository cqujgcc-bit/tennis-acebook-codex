@import "/styles/icons.wxss";

.venues { min-height: 100vh; background: #F4F6F5; padding-bottom: 60rpx; }

/* 顶部 */
.vh {
  background: linear-gradient(135deg, #0B3D2E 0%, #14653C 100%);
  padding: 30rpx 30rpx 36rpx;
}
.vh-title { color: #fff; font-size: 40rpx; font-weight: 700; }
.vh-subtitle { color: rgba(255,255,255,0.85); font-size: 26rpx; margin-top: 10rpx; }

/* 说明 */
.intro {
  margin: 26rpx 30rpx 8rpx;
  background: #fff; border-radius: 20rpx;
  padding: 26rpx 26rpx; display: flex; align-items: flex-start;
  box-shadow: 0 4rpx 14rpx rgba(11,61,46,0.05);
}
.intro-emoji {
  width: 64rpx; height: 64rpx; border-radius: 50%; flex-shrink: 0;
  background: rgba(212,255,63,0.25);
  display: flex; align-items: center; justify-content: center;
  font-size: 36rpx; margin-right: 20rpx;
}
.intro-text { flex: 1; font-size: 26rpx; color: #4A574F; line-height: 1.6; }

/* 官方预订平台直达（竖排列表） */
.booking-apps { padding: 24rpx 30rpx 6rpx; }
.ba-title { font-size: 28rpx; font-weight: 700; color: #0B3D2E; padding: 0 0 18rpx; }
.ba-list { display: flex; flex-direction: column; }
.ba-row {
  display: flex; align-items: center;
  padding: 24rpx 24rpx; margin-bottom: 16rpx;
  background: #fff; border-radius: 20rpx; border: 2rpx solid #E8F0EC;
  box-shadow: 0 4rpx 14rpx rgba(11,61,46,0.05);
}
.ba-emoji {
  width: 80rpx; height: 80rpx; border-radius: 50%; flex-shrink: 0;
  background: rgba(212,255,63,0.22);
  display: flex; align-items: center; justify-content: center;
  font-size: 44rpx; margin-right: 22rpx;
}
.ba-row-info { flex: 1; min-width: 0; }
.ba-name { font-size: 30rpx; font-weight: 700; color: #1A2420; }
.ba-desc { display: block; font-size: 22rpx; color: #8A968F; margin-top: 8rpx; line-height: 1.35; }
.ba-go {
  display: flex; align-items: center; flex-shrink: 0;
  padding: 14rpx 26rpx; margin-left: 16rpx;
  background: #0B3D2E; border-radius: 30rpx;
  font-size: 24rpx; color: #fff; font-weight: 600;
}
.ba-go-icon { width: 26rpx; height: 26rpx; margin-left: 8rpx; }

.vfooter { text-align: center; color: #B5C0BB; font-size: 22rpx; padding: 24rpx 30rpx 10rpx; }
