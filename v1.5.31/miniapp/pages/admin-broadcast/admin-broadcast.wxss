.page { min-height: 100vh; background: #f4f6f5; padding: 30rpx 24rpx; }
.card { background: #fff; border-radius: 24rpx; padding: 30rpx; box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.04); }
.field { margin-bottom: 36rpx; }
.field:last-child { margin-bottom: 0; }
.label { display: block; font-size: 26rpx; color: #666; margin-bottom: 16rpx; }
.input { background: #f2f4f3; border-radius: 12rpx; padding: 22rpx 24rpx; font-size: 30rpx; }
.textarea { width: 100%; box-sizing: border-box; height: 260rpx; background: #f2f4f3; border-radius: 12rpx; padding: 22rpx 24rpx; font-size: 30rpx; }
.count { display: block; text-align: right; font-size: 22rpx; color: #aaa; margin-top: 8rpx; }
.picker { background: #f2f4f3; border-radius: 12rpx; padding: 22rpx 24rpx; font-size: 30rpx; color: #333; }
.submit-btn { margin-top: 40rpx; background: #0B3D2E; color: #fff; font-size: 32rpx; border-radius: 999rpx; }
.tip { font-size: 22rpx; color: #aaa; text-align: center; margin-top: 24rpx; line-height: 1.5; }
