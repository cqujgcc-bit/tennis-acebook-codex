page { background: #ECEEF0; }
.chat-page { display: flex; flex-direction: column; height: 100vh; }

.msg-scroll { flex: 1; }
.msg-list { padding: 24rpx 24rpx 12rpx; }

.tip { text-align: center; color: #9AA0A6; font-size: 24rpx; padding: 40rpx 0; }

.sys-msg {
  text-align: center; font-size: 22rpx; color: #9AA0A6;
  margin: 16rpx auto; padding: 8rpx 20rpx;
  background: rgba(0,0,0,0.06); border-radius: 12rpx; display: inline-block;
  max-width: 80%;
}
.sys-msg { display: block; }

/* 普通消息 */
.msg { display: flex; align-items: flex-start; margin-bottom: 28rpx; }
.msg-self { flex-direction: row-reverse; }

.msg-avatar {
  width: 72rpx; height: 72rpx; border-radius: 16rpx; flex-shrink: 0;
  background: #0B3D2E; background-size: cover; background-position: center;
  display: flex; align-items: center; justify-content: center;
  color: #D4FF3F; font-size: 28rpx; font-weight: 700;
}
.msg-body { display: flex; flex-direction: column; max-width: 66%; margin: 0 18rpx; }
.msg-self .msg-body { align-items: flex-end; }
.msg-name { font-size: 22rpx; color: #8A9094; margin-bottom: 8rpx; }
.msg-bubble {
  padding: 18rpx 24rpx; border-radius: 18rpx;
  font-size: 28rpx; color: #1A1A1A; background: #fff;
  word-break: break-all; line-height: 1.5;
}
.msg-self .msg-bubble { background: #0B3D2E; color: #fff; }

/* 输入栏 */
.input-bar {
  display: flex; align-items: center;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #fff; box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.05);
}
.input-box {
  flex: 1; height: 76rpx; background: #F2F4F3; border-radius: 38rpx;
  padding: 0 28rpx; font-size: 28rpx;
}
.send-btn {
  margin-left: 16rpx; flex-shrink: 0;
  height: 76rpx; line-height: 76rpx; padding: 0 36rpx;
  background: #C7CDC9; color: #fff; border-radius: 38rpx;
  font-size: 28rpx; font-weight: 600;
}
.send-btn.active { background: #0B3D2E; }
