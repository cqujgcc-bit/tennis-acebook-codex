<view class="page" wx:if="{{!loading}}">
  <view class="card">
    <view class="field">
      <text class="label">标题</text>
      <input class="input" value="{{form.title}}" data-key="title" bindinput="onInput" placeholder="球局标题" />
    </view>
    <view class="field">
      <text class="label">日期</text>
      <picker mode="date" value="{{form.matchDate}}" bindchange="onDateChange">
        <view class="picker-val">{{form.matchDate || '请选择日期'}}</view>
      </picker>
    </view>
    <view class="field">
      <text class="label">开始时间</text>
      <picker mode="time" value="{{form.startTime}}" bindchange="onStartChange">
        <view class="picker-val">{{form.startTime || '请选择'}}</view>
      </picker>
    </view>
    <view class="field">
      <text class="label">结束时间</text>
      <picker mode="time" value="{{form.endTime}}" bindchange="onEndChange">
        <view class="picker-val">{{form.endTime || '请选择'}}</view>
      </picker>
    </view>
    <view class="field">
      <text class="label">场地名称</text>
      <input class="input" value="{{form.venueName}}" data-key="venueName" bindinput="onInput" placeholder="场馆名称" />
    </view>
    <view class="field">
      <text class="label">场地地址</text>
      <input class="input" value="{{form.venueAddress}}" data-key="venueAddress" bindinput="onInput" placeholder="详细地址" />
    </view>
    <view class="field">
      <text class="label">场地编号</text>
      <input class="input" value="{{form.courtNo}}" data-key="courtNo" bindinput="onInput" placeholder="如 3 号场" />
    </view>
  </view>

  <view class="card">
    <view class="field">
      <text class="label">总名额</text>
      <view class="stepper">
        <view class="step-btn {{form.maxParticipants <= minCap ? 'disabled' : ''}}" bindtap="onCapMinus">-</view>
        <text class="step-val">{{form.maxParticipants}}</text>
        <view class="step-btn" bindtap="onCapPlus">+</view>
      </view>
    </view>
    <view class="hint">名额不能小于当前已报名人数（{{minCap}} 人）。增加名额后可邀请新球友加入。</view>

    <block wx:if="{{feeRequired}}">
      <view class="field">
        <text class="label">人均费用(元)</text>
        <input class="input" type="digit" value="{{form.feePerPerson}}" data-key="feePerPerson" bindinput="onInput" placeholder="0.00" />
      </view>
      <view class="hint">提示：人均费用仅影响"报名预扣"。球局结束后将按<text class="strong">实际到场人数</text>重新均摊场地费，多退少补。</view>
    </block>
  </view>

  <view class="card">
    <view class="field col">
      <text class="label">球局说明</text>
      <textarea class="textarea" value="{{form.description}}" data-key="description" bindinput="onInput" placeholder="补充说明（可选）" />
    </view>
  </view>

  <view class="footer">
    <button class="btn-primary" loading="{{saving}}" bindtap="onSave">保存修改</button>
  </view>
</view>

<view class="loading" wx:else>加载中...</view>
