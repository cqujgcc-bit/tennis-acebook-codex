@import "/styles/icons.wxss";
@import "/styles/game-card.wxss";

.page {
  padding-bottom: 180rpx;
  min-height: 100vh;
  background: #F4F6F5;
}

/* ===== 头部 ===== */
.header {
  background: linear-gradient(135deg, #0B3D2E 0%, #14653C 100%);
  padding: 32rpx 32rpx 40rpx;
}
.title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.page-title {
  color: #fff;
  font-size: 46rpx;
  font-weight: 800;
}
.location {
  display: flex;
  align-items: center;
  color: rgba(255, 255, 255, 0.92);
  font-size: 26rpx;
}
.loc-icon { width: 26rpx; height: 26rpx; margin-right: 6rpx; }

/* ===== 搜索条 ===== */
.search-bar {
  padding: 16rpx 24rpx 8rpx;
}
.search-input-wrap {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 999rpx;
  padding: 0 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(11,61,46,0.06);
  border: 2rpx solid #E4EAE7;
}
.search-icon { font-size: 28rpx; margin-right: 12rpx; flex-shrink: 0; }
.search-input {
  flex: 1;
  height: 68rpx;
  font-size: 26rpx;
  color: #1A1A1A;
}
.search-clear {
  width: 40rpx; height: 40rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 26rpx; color: #9AA8A2; flex-shrink: 0;
}

/* ===== 筛选胶囊：一行平分铺满 ===== */
.filter-bar {
  display: flex;
  padding: 22rpx 20rpx 6rpx;
  gap: 10rpx;
}
.filter-item {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  background: #fff;
  border: 2rpx solid #E4EAE7;
  border-radius: 14rpx;
  font-size: 21rpx;
  color: #5A6863;
  white-space: nowrap;
  overflow: hidden;
}
.filter-item.active {
  background: #0B3D2E;
  border-color: #0B3D2E;
  color: #fff;
  font-weight: 600;
}

.game-list {
  padding: 16rpx 32rpx;
}
/* ===== 发起浮动按钮 ===== */
.fab {
  position: fixed;
  right: 36rpx;
  bottom: 56rpx;
  background: #0B3D2E;
  color: #fff;
  height: 92rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  padding: 0 38rpx;
  box-shadow: 0 10rpx 28rpx rgba(11, 61, 46, 0.4);
  border: 3rpx solid #D4FF3F;
}
.fab-plus { width: 34rpx; height: 34rpx; margin-right: 12rpx; }
.fab-text {
  font-size: 30rpx;
  font-weight: 700;
}
.empty {
  text-align: center;
  color: #9AA8A2;
  font-size: 28rpx;
  padding: 80rpx 0;
}

/* ============================================================
   v1.5.28 UI 运动风尚升级
   约球页：粘性筛选栏、卡片入场
   ============================================================ */

/* —— 筛选栏吸顶 —— */
.search-bar {
  position: sticky;
  top: 0;
  z-index: 20;
  background: #F4F6F5;
}

/* —— 筛选胶囊吸顶（跟随搜索条）—— */
.filter-bar {
  position: sticky;
  top: 92rpx;
  z-index: 19;
  background: #F4F6F5;
  padding-bottom: 16rpx;
}

/* —— 卡片入场动画 —— */
.game-card {
  animation: ab-card-enter 0.5s ease-out both;
}
.game-card:nth-child(1) { animation-delay: 0s; }
.game-card:nth-child(2) { animation-delay: 0.08s; }
.game-card:nth-child(3) { animation-delay: 0.16s; }
.game-card:nth-child(4) { animation-delay: 0.24s; }
.game-card:nth-child(5) { animation-delay: 0.32s; }
.game-card:nth-child(6) { animation-delay: 0.40s; }
.game-card:nth-child(7) { animation-delay: 0.48s; }
.game-card:nth-child(8) { animation-delay: 0.56s; }

/* —— 底部 FAB 悬浮按钮增强 —— */
.fab {
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}
.fab:active {
  transform: scale(0.94);
}

/* —— 筛选胶囊激活态增强 —— */
.filter-item {
  transition: all 0.2s ease;
}
.filter-item:active {
  transform: scale(0.94);
}
