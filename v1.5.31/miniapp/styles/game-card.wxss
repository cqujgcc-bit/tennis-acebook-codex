/* ===== 球局卡片（首页 + 约球页共用）===== */
.game-card {
  position: relative;
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  display: flex;
  box-shadow: 0 6rpx 20rpx rgba(11, 61, 46, 0.06);
}
.card-accent {
  width: 10rpx;
  background: #D4FF3F;
  flex-shrink: 0;
}
.card-full { opacity: 0.78; }
.card-full .card-accent { background: #D7DEDB; }
.card-body {
  flex: 1;
  padding: 24rpx 28rpx 28rpx;
  min-width: 0;
}

/* 顶部：左倒计时 + 右招募状态 */
.game-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.countdown {
  font-size: 23rpx;
  font-weight: 700;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
}
.countdown-placeholder { height: 1rpx; }
.cd-normal { background: #E7F2EC; color: #0B3D2E; }
.cd-soon   { background: #0B3D2E; color: #D4FF3F; }
.cd-urgent { background: #FFEAE7; color: #FF5A4D; }
.cd-live   { background: #E3F7E9; color: #0B9E45; }
.cd-ended  { background: #EFF1F0; color: #9AA8A2; }
.cd-done   { background: #FFF6D6; color: #B8860B; }

.game-status {
  font-size: 22rpx;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
  font-weight: 600;
}
.status-open { background: #0B3D2E; color: #D4FF3F; }
.status-full { background: #EFF1F0; color: #9AA8A2; }

.game-title-wrap { margin-bottom: 4rpx; }
.game-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A2420;
  line-height: 1.4;
}
.badge-circle {
  display: inline-block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #0B7A3E;
  background: #E7F6EC;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}

.game-meta { margin-top: 16rpx; }
.meta-item {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #5A6863;
  line-height: 1.9;
}
.meta-emoji { font-size: 26rpx; margin-right: 10rpx; }

.game-tags {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
}
.game-tags .tag {
  font-size: 22rpx;
  color: #5A6863;
  background: #F1F4F2;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}
.game-tags .tag-level {
  color: #0B3D2E;
  background: #E7F6EC;
  font-weight: 600;
}

.game-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #F0F2F1;
}

/* 发起人信息 */
.organizer {
  display: flex;
  align-items: center;
}
.avatar {
  background: #0B3D2E;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-weight: 600;
}
.avatar-sm {
  width: 48rpx;
  height: 48rpx;
  font-size: 26rpx;
}
.avatar-img { background: #E7F2EC; }
.org-name {
  margin-left: 14rpx;
  font-size: 26rpx;
  color: #5A6863;
}

/* 底部价格区 */
.bottom-right {
  display: flex;
  align-items: center;
}
.players-pill {
  display: flex;
  align-items: center;
  background: #D4FF3F;
  border-radius: 999rpx;
  padding: 6rpx 18rpx;
  margin-right: 18rpx;
}
.players-emoji { font-size: 22rpx; margin-right: 6rpx; }
.players-pill text {
  font-size: 24rpx;
  color: #0B3D2E;
  font-weight: 700;
}
.price {
  font-size: 30rpx;
  color: #FF5A4D;
  font-weight: 800;
}
.price-free { color: #0B7A3E; }
