<view class="page">
  <view wx:if="{{list.length > 0}}" class="topbar">
    <text class="topbar-unread">{{unreadCount > 0 ? unreadCount + ' 条未读' : '全部已读'}}</text>
    <text wx:if="{{unreadCount > 0}}" class="topbar-action" bindtap="onMarkAll">全部已读</text>
  </view>

  <view class="list">
    <view wx:for="{{list}}" wx:key="id" class="notif-card {{item.isRead ? '' : 'unread'}}" data-id="{{item.id}}" data-idx="{{index}}" bindtap="onTapItem">
      <view class="notif-icon {{item.iconClass}}">{{item.icon}}</view>
      <view class="notif-body">
        <view class="notif-title">
          {{item.title}}
          <view wx:if="{{!item.isRead}}" class="dot"></view>
        </view>
        <view class="notif-content">{{item.content}}</view>
        <view class="notif-time">{{item.timeText}}</view>
      </view>
    </view>
  </view>

  <view wx:if="{{!loading && list.length === 0}}" class="empty">
    <view class="empty-emoji">🔔</view>
    <view class="empty-text">还没有消息</view>
    <view class="empty-sub">报名、评论、圈子动态都会在这里通知你</view>
  </view>

  <view wx:if="{{loading}}" class="empty">
    <view class="empty-text">加载中…</view>
  </view>
</view>
