.page {
  min-height: 100vh;
  background: #f5f6f5;
  padding-bottom: 40rpx;
}

/* 统计 */
.stat-row {
  display: flex;
  gap: 24rpx;
  padding: 32rpx 32rpx 8rpx;
}
.stat-card {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 36rpx 0;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.stat-num {
  font-size: 56rpx;
  font-weight: 700;
  color: #0B3D2E;
  line-height: 1;
}
.stat-label {
  margin-top: 14rpx;
  font-size: 26rpx;
  color: #666;
}
.stat-hint {
  padding: 12rpx 32rpx 0;
  font-size: 22rpx;
  color: #999;
}

/* Tab */
.tabs {
  display: flex;
  margin: 28rpx 32rpx 0;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.tab {
  flex: 1;
  text-align: center;
  padding: 26rpx 0;
  font-size: 28rpx;
  color: #666;
}
.tab-active {
  color: #0B3D2E;
  font-weight: 700;
  background: #eef6f1;
}

/* 列表 */
.list {
  padding: 24rpx 32rpx 0;
}
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.card-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
  flex: 1;
  margin-right: 16rpx;
}
.state {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  white-space: nowrap;
}
.st-open { color: #0B3D2E; background: #e3f3ea; }
.st-full { color: #b26a00; background: #fdf0db; }
.st-ended { color: #888; background: #eee; }
.st-done { color: #1f7a4d; background: #d8f0e2; }
.st-cancel { color: #c0392b; background: #fbe4e1; }

.card-meta {
  margin-top: 14rpx;
  font-size: 26rpx;
  color: #555;
}
.card-foot {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
}
.tags {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}
.tag {
  font-size: 22rpx;
  color: #0B3D2E;
  background: #eef6f1;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}
.foot-right {
  display: flex;
  align-items: center;
  gap: 18rpx;
}
.players {
  font-size: 24rpx;
  color: #666;
}
.price {
  font-size: 26rpx;
  font-weight: 700;
  color: #e8852c;
}

/* 空态 */
.empty {
  text-align: center;
  padding: 100rpx 0;
}
.empty-emoji { font-size: 80rpx; }
.empty-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #999;
}
.empty-btn {
  display: inline-block;
  margin-top: 32rpx;
  padding: 18rpx 56rpx;
  background: #0B3D2E;
  color: #fff;
  font-size: 28rpx;
  border-radius: 999rpx;
}
.loading {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}


/* ── v1.5.33 新增 ── */

/* 待操作横幅 */
.pending-banner {
  display: flex;
  align-items: center;
  background: #FFF8F0;
  border: 2rpx solid #FFD9A0;
  border-radius: 16rpx;
  padding: 22rpx 24rpx;
  margin: 12rpx 0 16rpx;
  animation: ab-card-enter 0.3s ease-out both;
}
.pending-icon { font-size: 32rpx; margin-right: 12rpx; flex-shrink: 0; }
.pending-text { font-size: 26rpx; color: #B07A3E; font-weight: 600; flex: 1; }

/* 分区标签 */
.section-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #1A2420;
  padding: 18rpx 12rpx 12rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.section-open { color: #0B3D2E; }
.history-arrow { font-size: 23rpx; color: #8A968F; font-weight: 400; }

/* 历史卡片弱化 */
.card-history { opacity: 0.7; }
.history-section { margin-bottom: 8rpx; }
