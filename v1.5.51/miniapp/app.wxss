/* app.wxss 全局样式 - 深森林绿主题 */
page {
  background-color: #f5f7f6;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, sans-serif;
  color: #1a1a1a;
  font-size: 28rpx;
}

view,
text,
button,
input {
  box-sizing: border-box;
}

/* 主题色变量（仅用于参考，wxss 不支持 var 在所有端，直接写值） */
/* primary: #0B3D2E  dark: #2d5a47  light: #6ba88a */

/* 通用卡片 */
.card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

/* 主按钮 */
.btn-primary {
  background-color: #0B3D2E;
  color: #fff;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}
.btn-primary::after {
  border: none;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background-color: #eaf3ee;
  color: #0B3D2E;
  margin-right: 12rpx;
}

.tag-orange {
  background-color: #fff3e0;
  color: #e89c2c;
}

/* 头像（文字头像兜底） */
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #0B3D2E;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  flex-shrink: 0;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 120rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 文字省略 */
.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.flex {
  display: flex;
  align-items: center;
}
.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* ============================================================
   统一设计规范（v1.5.17 设计师小改动）
   色板：主墨绿 #0B3D2E / 网球黄 #D4FF3F / 主文字 #1A2420
        次文字 #5A6863 / 弱文字 #8A968F / 背景 #F4F6F5
   圆角：小 8rpx / 中 16rpx / 大 24rpx / 全圆 999rpx
   边距：页边 30rpx / 卡片内 28rpx
   ============================================================ */

/* —— 通用页头（墨绿渐变，管理后台/钱包/关于等统一用）—— */
.ab-header {
  background: linear-gradient(135deg, #0B3D2E 0%, #14653C 100%);
  padding: 36rpx 30rpx 40rpx;
  color: #fff;
}
.ab-header-title { font-size: 40rpx; font-weight: 800; }
.ab-header-sub { font-size: 26rpx; opacity: 0.85; margin-top: 10rpx; }

/* —— 通用卡片（统一圆角/阴影/内边距）—— */
.ab-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin: 24rpx 30rpx 0;
  box-shadow: 0 6rpx 20rpx rgba(11,61,46,0.06);
}

/* —— 列表型卡片项 —— */
.ab-list-item {
  display: flex;
  align-items: center;
  padding: 28rpx;
  border-bottom: 2rpx solid #F0F2F1;
}
.ab-list-item:last-child { border-bottom: none; }

/* —— 主/次按钮（胶囊）—— */
.ab-btn {
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.08s ease, opacity 0.08s ease;
}
.ab-btn-primary { background: linear-gradient(135deg, #0B3D2E 0%, #14653C 100%); color: #fff; }
.ab-btn-ghost { background: #fff; border: 2rpx solid #0B3D2E; color: #0B3D2E; }
.ab-btn-hover { transform: scale(0.97); opacity: 0.9; }
.ab-btn::after { border: none; }

/* —— 胶囊标签/徽章 —— */
.ab-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  background: #E7F6EC;
  color: #0B3D2E;
}
.ab-tag-yellow { background: #D4FF3F; color: #0B3D2E; font-weight: 700; }
.ab-tag-gray { background: #EFF1F0; color: #9AA8A2; }

/* —— 统一空状态（emoji + 标题 + 副文案 + 可选按钮）—— */
.ab-empty { text-align: center; padding: 110rpx 60rpx; }
.ab-empty-emoji { font-size: 96rpx; line-height: 1; }
.ab-empty-title { font-size: 32rpx; font-weight: 700; color: #1A2420; margin-top: 20rpx; }
.ab-empty-sub { font-size: 26rpx; color: #8A968F; margin-top: 12rpx; line-height: 1.5; }

/* —— 统一加载态 —— */
.ab-loading {
  text-align: center;
  padding: 80rpx 0;
  color: #8A968F;
  font-size: 26rpx;
}
.ab-loading-spin {
  display: inline-block;
  width: 44rpx; height: 44rpx;
  border: 5rpx solid #E4EAE7;
  border-top-color: #0B3D2E;
  border-radius: 50%;
  animation: ab-spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}
@keyframes ab-spin { to { transform: rotate(360deg); } }
/* ============================================================
   v1.5.28 UI 运动风尚升级
   新增：动画关键帧、能量色板、实用工具类、骨架屏、统计条
   ============================================================ */

/* —— 卡片入场动画（首页 / 约球页 / 圈子卡片通用）—— */
@keyframes ab-card-enter {
  from { opacity: 0; transform: translateY(32rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

/* —— Hero 品牌字微光脉冲 —— */
@keyframes ab-pulse-glow {
  0%   { text-shadow: 0 2rpx 12rpx rgba(0,0,0,0.25); }
  50%  { text-shadow: 0 0 28rpx rgba(212,255,63,0.35), 0 2rpx 12rpx rgba(0,0,0,0.25); }
  100% { text-shadow: 0 2rpx 12rpx rgba(0,0,0,0.25); }
}

/* —— 骨架屏 shimmer —— */
@keyframes ab-shimmer {
  0%   { background-position: -400rpx 0; }
  100% { background-position: 400rpx 0; }
}

/* —— 弹跳加载指示 —— */
@keyframes ab-bounce {
  0%, 100% { transform: translateY(0); }
  50%      { transform: translateY(-12rpx); }
}

/* —— 能量色板（运动风着色）—— */
.ab-text-muted  { color: #8A968F; }
.ab-text-price  { color: #E85C5C; font-weight: 700; }
.ab-text-energy { color: #D4FF3F; }
.ab-text-coral  { color: #FF6B4A; }
.ab-text-amber  { color: #D98A2B; }
.ab-bg-coral    { background: #FF6B4A; }
.ab-bg-energy   { background: #D4FF3F; color: #0B3D2E; }
.ab-bg-dark     { background: #0B3D2E; }

/* —— 分割线 —— */
.ab-divider {
  height: 2rpx;
  background: #EBEEED;
  margin: 20rpx 0;
}

/* —— 统计数值条（仪表盘 / 圈子统计复用）—— */
.ab-stat-bar {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: rgba(255,255,255,0.10);
  border-radius: 20rpx;
  padding: 22rpx 14rpx;
}
.ab-stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.ab-stat-num {
  font-size: 40rpx;
  font-weight: 800;
  color: #D4FF3F;
}
.ab-stat-label {
  font-size: 23rpx;
  color: rgba(255,255,255,0.82);
  margin-top: 6rpx;
}

/* —— 骨架屏元素 —— */
.ab-skeleton {
  background: linear-gradient(90deg, #EDF1EF 25%, #F5F8F6 50%, #EDF1EF 75%);
  background-size: 800rpx 100%;
  animation: ab-shimmer 1.6s ease-in-out infinite;
  border-radius: 12rpx;
}
.ab-skeleton-line {
  height: 28rpx;
  margin-bottom: 16rpx;
}
.ab-skeleton-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

/* —— 倒计时徽章（简化命名，与 game-card 互补）—— */
.ab-cd-badge {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  font-size: 23rpx;
  font-weight: 700;
}
.ab-cd-normal { background: #E7F2EC; color: #0B3D2E; }
.ab-cd-soon   { background: #0B3D2E; color: #D4FF3F; }
.ab-cd-urgent { background: #FFEAE7; color: #FF5A4D; }
.ab-cd-live   { background: #E3F7E9; color: #0B9E45; }
.ab-cd-ended  { background: #EFF1F0; color: #9AA8A2; }
