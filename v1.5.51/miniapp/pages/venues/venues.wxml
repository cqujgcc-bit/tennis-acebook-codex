<view class="venues">
  <!-- 顶部（墨绿） -->
  <view class="vh">
    <view class="vh-title">找场地</view>
    <view class="vh-subtitle">深圳网球场馆 · 官方小程序预订直达</view>
  </view>

  <!-- 说明 -->
  <view class="intro">
    <view class="intro-emoji">🎾</view>
    <view class="intro-text">
      点击下方任一官方/合作小程序，即可在线预订对应平台的网球场馆：覆盖深圳湾、香蜜、中心公园、荔香、坪山、宝安等公共场馆，以及高时、尚酷等专业网球场。按需选择平台进入预订即可。
    </view>
  </view>

  <!-- 小程序预订平台（竖排列表） -->
  <view class="booking-apps">
    <view class="ba-title">官方预订平台 · 一键直达</view>
    <view class="ba-list">
      <view wx:for="{{bookingApps}}" wx:key="id" class="ba-row" data-id="{{item.id}}" bindtap="onOpenApp">
        <view class="ba-emoji">{{item.emoji}}</view>
        <view class="ba-row-info">
          <text class="ba-name">{{item.name}}</text>
          <text class="ba-desc">{{item.desc}}</text>
        </view>
        <view class="ba-go">
          <text>去预订</text>
          <view class="ab-icon ab-icon-applet-white ba-go-icon"></view>
        </view>
      </view>
    </view>
  </view>

  <view class="vfooter">预订及收费以各场馆官方小程序信息为准</view>
</view>
