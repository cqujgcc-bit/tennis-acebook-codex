.page {
  padding-bottom: 60rpx;
}

.banner {
  background-color: #0B3D2E;
  padding: 40rpx 32rpx 48rpx;
  color: #fff;
}

.banner-title {
  font-size: 40rpx;
  font-weight: 700;
}

.banner-sub {
  font-size: 26rpx;
  opacity: 0.85;
  margin-top: 12rpx;
}

.coach-list {
  padding: 24rpx 32rpx 0;
}

.coach-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.coach-top {
  display: flex;
}

.coach-avatar {
  width: 100rpx;
  height: 100rpx;
  font-size: 40rpx;
  border-radius: 24rpx;
}

.coach-main {
  flex: 1;
  margin-left: 24rpx;
}

.coach-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.coach-name {
  font-size: 32rpx;
  font-weight: 700;
}

.coach-rating {
  font-size: 26rpx;
  color: #e89c2c;
}

.coach-level {
  display: block;
  font-size: 24rpx;
  color: #0B3D2E;
  margin-top: 6rpx;
}

.coach-intro {
  display: block;
  font-size: 26rpx;
  color: #888;
  margin-top: 8rpx;
}

.coach-tags {
  margin-top: 16rpx;
}

.coach-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.coach-loc {
  font-size: 24rpx;
  color: #666;
}

.coach-price {
  font-size: 36rpx;
  color: #e89c2c;
  font-weight: 700;
}

.coach-unit {
  font-size: 24rpx;
  color: #999;
}

.tip {
  text-align: center;
  color: #aaa;
  font-size: 24rpx;
  padding: 24rpx;
}
