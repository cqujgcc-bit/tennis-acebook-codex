.page { min-height: 100vh; background: #f4f6f5; padding-bottom: 60rpx; }

.overview { background: linear-gradient(135deg, #0B3D2E 0%, #14503C 100%); padding: 36rpx 30rpx 30rpx; color: #fff; }
.ov-row { display: flex; justify-content: space-between; margin-bottom: 16rpx; }
.ov-item { flex: 1; text-align: center; }
.ov-num { display: block; font-size: 40rpx; font-weight: 700; letter-spacing: 1rpx; }
.ov-num.income { color: #7fdb9a; }
.ov-num.settled { color: #81ecec; }
.ov-num.pending { color: #fdcb6e; }
.ov-num.refunded { color: #fab1a0; }
.ov-label { display: block; font-size: 22rpx; opacity: 0.85; margin-top: 6rpx; }
.ov-divider { height: 1rpx; background: rgba(255,255,255,0.15); margin: 16rpx 0; }
.ov-balance { display: flex; flex-direction: column; align-items: center; padding: 8rpx 0; }
.ov-bal-label { font-size: 24rpx; opacity: 0.85; }
.ov-bal-num { font-size: 56rpx; font-weight: 700; margin-top: 6rpx; }
.ov-note { font-size: 20rpx; opacity: 0.6; margin-top: 14rpx; line-height: 1.5; text-align: center; }

.section-title { font-size: 28rpx; color: #555; font-weight: 600; margin: 36rpx 32rpx 18rpx; }

.stat-grid { display: flex; flex-wrap: wrap; padding: 0 22rpx; }
.stat-card { width: calc(25% - 20rpx); margin: 10rpx; background: #fff; border-radius: 20rpx; padding: 24rpx 10rpx; text-align: center; box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.04); }
.stat-num { font-size: 38rpx; font-weight: 700; color: #0B3D2E; }
.stat-num.income { color: #27ae60; }
.stat-num.settled { color: #0984e3; }
.stat-num.refunded { color: #d63031; }
.stat-label { font-size: 20rpx; color: #888; margin-top: 6rpx; }

.list { margin: 0 24rpx; background: #fff; border-radius: 20rpx; overflow: hidden; }
.item { display: flex; align-items: center; justify-content: space-between; padding: 24rpx 28rpx; border-top: 1rpx solid #f2f2f2; }
.item:first-of-type { border-top: none; }
.item-left { display: flex; flex-direction: column; flex: 1; padding-right: 20rpx; }
.item-title { font-size: 28rpx; color: #222; font-weight: 500; }
.item-sub { font-size: 22rpx; color: #999; margin-top: 6rpx; }
.item-right { display: flex; flex-direction: column; align-items: flex-end; }
.item-amount { font-size: 32rpx; font-weight: 700; color: #0B3D2E; }
.item-status { font-size: 20rpx; margin-top: 4rpx; }
.item-status.done { color: #0B3D2E; }
.item-status.pending { color: #b8862f; }
.item-status.disputed { color: #c0392b; }

.empty { text-align: center; padding: 60rpx; }
.empty-text { font-size: 26rpx; color: #aaa; }

.withdraw-card { margin: 0 24rpx; background: #fff; border-radius: 20rpx; padding: 28rpx; box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.04); }
.withdraw-desc { display: block; font-size: 24rpx; color: #888; line-height: 1.5; margin-bottom: 20rpx; }
.withdraw-form { margin-bottom: 20rpx; }
.withdraw-input { display: block; width: 100%; height: 80rpx; border: 1rpx solid #e0e0e0; border-radius: 12rpx; padding: 0 20rpx; font-size: 30rpx; box-sizing: border-box; margin-bottom: 16rpx; }
.withdraw-desc-input { display: block; width: 100%; height: 80rpx; border: 1rpx solid #e0e0e0; border-radius: 12rpx; padding: 0 20rpx; font-size: 26rpx; box-sizing: border-box; }
.withdraw-btn { width: 100%; height: 88rpx; background: #0B3D2E; color: #fff; border-radius: 44rpx; font-size: 30rpx; font-weight: 600; line-height: 88rpx; text-align: center; border: none; }
.withdraw-btn:disabled { opacity: 0.5; }

.loading-tip { text-align: center; color: #999; font-size: 26rpx; padding: 30rpx; }
