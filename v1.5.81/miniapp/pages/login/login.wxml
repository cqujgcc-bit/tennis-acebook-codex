<view class="login-page">
  <view class="bg-deco"></view>
  <view class="bg-deco2"></view>

  <view class="content">
    <view class="logo-box">
      <view class="logo-circle">
        <text class="logo-emoji">🎾</text>
      </view>
      <view class="brand">AceBook</view>
      <view class="slogan">约球 · 找场地 · 一站式网球服务</view>
    </view>

    <view class="login-card" wx:if="{{!showProfile}}">
      <button
        class="btn-wechat"
        open-type="getPhoneNumber"
        bindgetphonenumber="handleWechatLogin"
        loading="{{logging}}"
        disabled="{{logging}}"
      >
        <text class="ico">🎾</text>
        <text class="btn-text">微信一键登录</text>
      </button>

      <view class="tips">登录即表示同意 用户协议 与 隐私政策</view>
    </view>
  </view>
</view>

<!-- 完善资料弹层：登录成功后若缺头像/性别则弹出 -->
<view class="profile-mask" wx:if="{{showProfile}}">
  <view class="profile-sheet">
    <view class="ps-title">完善个人资料</view>
    <view class="ps-sub">填写资料，让球友更快认识你</view>

    <!-- 昵称 -->
    <view class="nickname-row">
      <text class="nickname-label">昵称</text>
      <input class="nickname-input" type="nickname" placeholder="你的昵称" value="{{form.nickname}}" bindinput="onNicknameInput" />
    </view>

    <!-- 微信头像授权 -->
    <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image wx:if="{{form.avatar}}" class="avatar-img" src="{{form.avatar}}" mode="aspectFill"></image>
      <view wx:else class="avatar-placeholder">
        <text class="ap-emoji">🎾</text>
        <text class="ap-text">点击选择头像</text>
      </view>
    </button>

    <!-- 性别选择 -->
    <view class="gender-label">性别</view>
    <view class="gender-row">
      <view class="gender-pill {{form.gender==='male'?'on':''}}" data-g="male" bindtap="onPickGender">♂ 男</view>
      <view class="gender-pill {{form.gender==='female'?'on':''}}" data-g="female" bindtap="onPickGender">♀ 女</view>
      <view class="gender-pill {{form.gender===''?'on':''}}" data-g="" bindtap="onPickGender">保密</view>
    </view>

    <!-- 网球水平选择 -->
    <view class="gender-label">网球水平（NTRP）</view>
    <view class="ntrp-list">
      <view
        class="ntrp-item {{form.ntrpLevel===item.value?'on':''}}"
        wx:for="{{ntrpOptions}}"
        wx:key="value"
        data-v="{{item.value}}"
        bindtap="onPickNtrp"
      >
        <view class="ntrp-head">
          <text class="ntrp-label">{{item.label}}</text>
          <text class="ntrp-val">{{item.value}}</text>
        </view>
        <text class="ntrp-desc">{{item.desc}}</text>
      </view>
    </view>

    <button class="ps-confirm" bindtap="onSaveProfile" loading="{{saving}}" disabled="{{saving}}">完成</button>
    <view class="ps-skip" bindtap="onSkipProfile">暂时跳过</view>
  </view>
</view>
