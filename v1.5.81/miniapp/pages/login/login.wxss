.login-page {
  min-height: 100vh;
  background: linear-gradient(160deg, #0B3D2E 0%, #0E4A36 55%, #093526 100%);
  position: relative;
  overflow: hidden;
}

/* 装饰：右上大圆 + 网球黄光斑 */
.bg-deco {
  position: absolute;
  top: -220rpx; right: -200rpx;
  width: 600rpx; height: 600rpx;
  border-radius: 50%;
  background: rgba(212,255,63,0.10);
}
.bg-deco2 {
  position: absolute;
  bottom: -160rpx; left: -160rpx;
  width: 460rpx; height: 460rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.05);
}

.content {
  position: relative; z-index: 2;
  padding: 180rpx 60rpx 80rpx;
  display: flex; flex-direction: column; align-items: center;
  min-height: 100vh;
}

.logo-box { display: flex; flex-direction: column; align-items: center; margin-top: 60rpx; }
.logo-circle {
  width: 184rpx; height: 184rpx; border-radius: 46rpx;
  background: #D4FF3F;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 16rpx 40rpx rgba(212,255,63,0.28);
}
.logo-emoji { font-size: 104rpx; }

.brand {
  color: #fff; font-size: 66rpx; font-weight: 800;
  margin-top: 44rpx; letter-spacing: 2rpx; font-style: italic;
}
.slogan { color: rgba(255,255,255,0.82); font-size: 28rpx; margin-top: 16rpx; }

.login-card {
  width: 100%;
  background: rgba(255,255,255,0.97);
  border-radius: 32rpx;
  padding: 56rpx 48rpx;
  margin-top: 140rpx;
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.22);
}

.btn-wechat {
  width: 100%; height: 94rpx; border-radius: 999rpx;
  font-size: 32rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  background: #0B3D2E; color: #fff; margin-bottom: 24rpx;
}
.btn-wechat::after { border: none; }
.btn-wechat[disabled] { opacity: 0.7; }

.ico { margin-right: 12rpx; font-size: 30rpx; }
.btn-text { white-space: nowrap; }

.tips { text-align: center; color: #9AA0A6; font-size: 22rpx; margin-top: 40rpx; }

/* ─── 完善资料弹层 ─────────────────────────────── */
.profile-mask {
  position: fixed; inset: 0; z-index: 100;
  background: rgba(0,0,0,0.5);
  display: flex; align-items: flex-end;
}
.profile-sheet {
  width: 100%;
  background: #fff;
  border-radius: 40rpx 40rpx 0 0;
  padding: 56rpx 48rpx calc(48rpx + env(safe-area-inset-bottom));
  animation: sheetUp 0.25s ease;
}
@keyframes sheetUp { from { transform: translateY(100%); } to { transform: translateY(0); } }

.ps-title { font-size: 38rpx; font-weight: 800; color: #0B3D2E; text-align: center; }
.ps-sub { font-size: 26rpx; color: #9AA0A6; text-align: center; margin-top: 12rpx; margin-bottom: 44rpx; }

.avatar-btn {
  width: 180rpx; height: 180rpx; padding: 0;
  border-radius: 50%; margin: 0 auto 12rpx; overflow: hidden;
  background: #F2F4F3; display: flex; align-items: center; justify-content: center;
  border: 4rpx solid #D4FF3F;
}
.avatar-btn::after { border: none; }
.avatar-img { width: 100%; height: 100%; }
.avatar-placeholder { display: flex; flex-direction: column; align-items: center; justify-content: center; }
.ap-emoji { font-size: 60rpx; }
.ap-text { font-size: 22rpx; color: #9AA0A6; margin-top: 8rpx; }

.gender-label { font-size: 28rpx; color: #333; font-weight: 600; margin: 40rpx 0 20rpx; }
.gender-row { display: flex; gap: 20rpx; }
.gender-pill {
  flex: 1; height: 88rpx; border-radius: 16rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 30rpx; color: #555; background: #F2F4F3;
  border: 2rpx solid transparent;
}
.gender-pill.on { background: rgba(11,61,46,0.08); color: #0B3D2E; border-color: #0B3D2E; font-weight: 700; }

.nickname-row { margin-bottom: 32rpx; }
.nickname-label { font-size: 28rpx; color: #333; font-weight: 600; margin-bottom: 16rpx; display: block; }
.nickname-input { width: 100%; height: 88rpx; line-height: 88rpx; border: 2rpx solid #E4EAE7; border-radius: 16rpx; padding: 0 24rpx; font-size: 28rpx; color: #1A1A1A; background: #F8F9F8; }

.ps-confirm {
  width: 100%; height: 94rpx; border-radius: 999rpx;
  background: #0B3D2E; color: #fff; font-size: 32rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  margin-top: 48rpx;
}
.ps-confirm::after { border: none; }
.ps-skip { text-align: center; color: #9AA0A6; font-size: 26rpx; margin-top: 28rpx; }

/* 网球水平选择列表 */
.ntrp-list {
  display: flex; flex-direction: column; gap: 16rpx;
  max-height: 460rpx; overflow-y: auto;
}
.ntrp-item {
  padding: 20rpx 24rpx; border-radius: 16rpx;
  background: #F2F4F3; border: 2rpx solid transparent;
}
.ntrp-item.on {
  background: rgba(11,61,46,0.08); border-color: #0B3D2E;
}
.ntrp-head { display: flex; align-items: center; justify-content: space-between; }
.ntrp-label { font-size: 30rpx; color: #333; font-weight: 700; }
.ntrp-item.on .ntrp-label { color: #0B3D2E; }
.ntrp-val {
  font-size: 26rpx; font-weight: 700; color: #0B3D2E;
  background: rgba(212,255,63,0.45); padding: 2rpx 16rpx; border-radius: 999rpx;
}
.ntrp-desc { display: block; font-size: 24rpx; color: #9AA0A6; margin-top: 8rpx; }
