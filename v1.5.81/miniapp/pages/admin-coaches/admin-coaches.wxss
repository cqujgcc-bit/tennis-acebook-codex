.page { min-height: 100vh; background: #f4f6f5; padding: 24rpx; }
.loading-tip { text-align: center; color: #999; font-size: 28rpx; padding: 80rpx 0; }
.empty { display: flex; flex-direction: column; align-items: center; color: #999; font-size: 28rpx; padding: 120rpx 0; }
.empty-emoji { font-size: 80rpx; margin-bottom: 20rpx; }

.c-card { background: #fff; border-radius: 24rpx; padding: 30rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.04); }
.c-top { display: flex; align-items: center; margin-bottom: 24rpx; }
.c-avatar { width: 96rpx; height: 96rpx; border-radius: 50%; background: #eee; margin-right: 22rpx; }
.c-name { font-size: 34rpx; font-weight: 700; color: #222; }
.c-tagline { font-size: 24rpx; color: #888; margin-top: 8rpx; }
.c-row { display: flex; font-size: 26rpx; padding: 10rpx 0; }
.c-k { width: 150rpx; color: #999; }
.c-v { flex: 1; color: #333; }
.c-bio { font-size: 26rpx; color: #555; line-height: 1.6; background: #f7f9f7; border-radius: 12rpx; padding: 18rpx; margin-top: 16rpx; }
.c-imgs { display: flex; flex-wrap: wrap; margin-top: 18rpx; }
.cert-img { width: 200rpx; height: 200rpx; border-radius: 12rpx; margin: 10rpx 10rpx 0 0; background: #eee; }
.c-actions { display: flex; justify-content: flex-end; margin-top: 24rpx; }
.btn { margin-left: 20rpx; font-size: 26rpx; }
.btn.reject { background: #fff; color: #ff4d4f; border: 1rpx solid #ff4d4f; }
.btn.approve { background: #0B3D2E; color: #fff; }
