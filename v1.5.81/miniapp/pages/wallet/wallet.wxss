.page { min-height: 100vh; background: #f3f5f4; padding-bottom: 40rpx; }

/* 概览卡 */
.overview {
  background: linear-gradient(135deg, #0B3D2E 0%, #14503C 100%);
  padding: 48rpx 40rpx 36rpx;
  color: #fff;
}
.ov-main { display: flex; flex-direction: column; }
.ov-label { font-size: 24rpx; opacity: 0.85; }
.ov-amount { font-size: 68rpx; font-weight: 700; margin-top: 8rpx; letter-spacing: 1rpx; }
.ov-sub { display: flex; align-items: center; justify-content: space-between; margin-top: 20rpx; padding-top: 20rpx; border-top: 1rpx solid rgba(255,255,255,0.18); }
.ov-sub-label { font-size: 24rpx; opacity: 0.85; }
.ov-sub-amount { font-size: 30rpx; font-weight: 600; }
.ov-note { margin-top: 18rpx; font-size: 20rpx; opacity: 0.7; line-height: 1.5; }

/* Tabs */
.tabs { display: flex; background: #fff; margin: 0; }
.tab { flex: 1; text-align: center; padding: 28rpx 0; font-size: 28rpx; color: #888; position: relative; }
.tab-on { color: #0B3D2E; font-weight: 600; }
.tab-on::after { content: ''; position: absolute; left: 50%; bottom: 10rpx; transform: translateX(-50%); width: 48rpx; height: 6rpx; border-radius: 3rpx; background: #0B3D2E; }

/* 分组 */
.group { margin: 24rpx 24rpx 0; background: #fff; border-radius: 20rpx; overflow: hidden; }
.group-title { font-size: 24rpx; color: #999; padding: 22rpx 28rpx 8rpx; }

.item { display: flex; align-items: center; justify-content: space-between; padding: 24rpx 28rpx; border-top: 1rpx solid #f2f2f2; }
.item:first-of-type { border-top: none; }
.item-left { display: flex; flex-direction: column; flex: 1; padding-right: 20rpx; }
.item-title { font-size: 28rpx; color: #222; font-weight: 500; }
.item-sub { font-size: 22rpx; color: #999; margin-top: 8rpx; }
.item-right { display: flex; flex-direction: column; align-items: flex-end; }
.item-amount { font-size: 32rpx; font-weight: 700; }
.item-amount.income { color: #0B3D2E; }
.item-amount.pending { color: #b8862f; }
.item-amount.disputed { color: #c0392b; }
.item-amount.expense { color: #444; }
.item-status { font-size: 20rpx; color: #aaa; margin-top: 6rpx; }
.item-status.done { color: #0B3D2E; }

/* 空状态 */
.empty { display: flex; flex-direction: column; align-items: center; padding: 100rpx 60rpx; }
.empty-ico { font-size: 72rpx; }
.empty-text { font-size: 30rpx; color: #555; margin-top: 20rpx; }
.empty-sub { font-size: 24rpx; color: #aaa; margin-top: 12rpx; text-align: center; line-height: 1.6; }

.foot-note { font-size: 22rpx; color: #b0b0b0; text-align: center; padding: 36rpx 48rpx 0; line-height: 1.6; }

/* V6 待补缴卡片 */
.topup-card { margin: 24rpx; background: linear-gradient(135deg, #fff7e6, #fff); border: 1rpx solid #ffe0a3; border-radius: 20rpx; padding: 24rpx 28rpx; }
.topup-card-head { margin-bottom: 16rpx; }
.topup-card-title { display: block; color: #e08a00; font-size: 32rpx; font-weight: 800; }
.topup-card-sub { display: block; color: #b58a4a; font-size: 23rpx; margin-top: 8rpx; line-height: 1.5; }
.topup-row { display: flex; align-items: center; justify-content: space-between; padding: 18rpx 0; border-top: 1rpx solid #ffeccb; }
.topup-row-left { display: flex; flex-direction: column; }
.topup-row-title { font-size: 28rpx; color: #1a1a1a; font-weight: 500; }
.topup-row-sub { font-size: 23rpx; color: #b58a4a; margin-top: 6rpx; }
.topup-row-right { display: flex; align-items: center; }
.topup-row-amt { color: #e08a00; font-size: 30rpx; font-weight: 700; margin-right: 18rpx; }
.topup-row-btn { background: #e08a00; color: #fff; padding: 10rpx 22rpx; border-radius: 999rpx; font-size: 24rpx; font-weight: 600; }
