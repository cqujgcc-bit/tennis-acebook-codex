.page { min-height: 100vh; background: #f5f6f8; padding: 20rpx 20rpx 180rpx; box-sizing: border-box; }
.loading, .empty { text-align: center; color: #999; padding: 100rpx 0; }

.head { background: #fff; border-radius: 16rpx; padding: 28rpx; margin-bottom: 20rpx; }
.title { font-size: 32rpx; font-weight: 600; color: #1a1a1a; display: block; }
.sub { font-size: 24rpx; color: #999; display: block; margin-top: 10rpx; line-height: 1.5; }

.cost-box { background: #fff; border-radius: 16rpx; padding: 28rpx; display: flex; align-items: center; }
.cost-label { font-size: 28rpx; color: #333; flex-shrink: 0; }
.cost-input { flex: 1; text-align: right; font-size: 40rpx; color: #fb8c00; font-weight: 600; }
.preview { background: #fff3e0; color: #fb8c00; font-size: 26rpx; padding: 18rpx 28rpx; border-radius: 12rpx; margin-top: 14rpx; }

.sec-title { font-size: 26rpx; color: #999; margin: 28rpx 8rpx 14rpx; }
.mlist { background: #fff; border-radius: 16rpx; overflow: hidden; }
.mitem, .bitem { display: flex; align-items: center; padding: 22rpx 28rpx; border-bottom: 1rpx solid #f5f5f5; }
.mitem:last-child, .bitem:last-child { border-bottom: none; }
.m-av { width: 64rpx; height: 64rpx; border-radius: 50%; background: #eee; margin-right: 20rpx; }
.m-name { font-size: 28rpx; color: #1a1a1a; flex: 1; }
.check { font-size: 25rpx; padding: 8rpx 24rpx; border-radius: 999rpx; background: #f2f3f5; color: #999; }
.check-on { background: #e8f5e9; color: #43a047; }

.b-info { flex: 1; display: flex; flex-direction: column; }
.b-sub { font-size: 24rpx; color: #888; margin-top: 6rpx; }
.b-status { font-size: 26rpx; padding-left: 16rpx; }
.s-paid { color: #43a047; }
.s-unpaid { color: #fb8c00; }
.s-none { color: #bbb; }

.bill-summary { background: #fff; border-radius: 16rpx; display: flex; padding: 32rpx 0; }
.bs-item { flex: 1; display: flex; flex-direction: column; align-items: center; }
.bs-num { font-size: 38rpx; font-weight: 600; color: #1a1a1a; }
.bs-red { color: #fb8c00; }
.bs-lab { font-size: 23rpx; color: #999; margin-top: 8rpx; }

.footer { position: fixed; left: 0; right: 0; bottom: 0; padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom)); background: #fff; box-shadow: 0 -2rpx 12rpx rgba(0,0,0,.04); }
.btn { width: 100%; height: 88rpx; line-height: 88rpx; font-size: 30rpx; border-radius: 999rpx; }
.btn::after { border: none; }
.btn-primary { background: #1aad19; color: #fff; }
.done-tip { text-align: center; color: #43a047; font-size: 28rpx; padding: 40rpx 0; }
