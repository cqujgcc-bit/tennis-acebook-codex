page { background: #F4F6F5; }
.page { min-height: 100vh; padding-bottom: 40rpx; }

.topbar {
  display: flex; align-items: center; justify-content: space-between;
  padding: 24rpx 32rpx; background: #fff;
  position: sticky; top: 0; z-index: 5;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.04);
}
.topbar-unread { font-size: 26rpx; color: #6B7280; }
.topbar-action { font-size: 27rpx; color: #0B3D2E; font-weight: 700; }

.list { padding: 24rpx 32rpx; }
.notif-card {
  display: flex; background: #fff; border-radius: 20rpx;
  padding: 26rpx 24rpx; margin-bottom: 18rpx;
  box-shadow: 0 4rpx 14rpx rgba(0,0,0,0.04);
}
.notif-card.unread { background: #F7FBF4; }

.notif-icon {
  width: 76rpx; height: 76rpx; border-radius: 50%; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  font-size: 36rpx; background: #EAF3ED;
}
.ic-match { background: #EAF3ED; }
.ic-cancel { background: #FDECEC; }
.ic-circle { background: #FFF6E5; }
.ic-social { background: #EAF0FB; }
.ic-default { background: #EEF0EF; }

.notif-body { flex: 1; margin-left: 20rpx; min-width: 0; }
.notif-title {
  display: flex; align-items: center;
  font-size: 29rpx; font-weight: 700; color: #1A1A1A;
}
.dot { width: 14rpx; height: 14rpx; border-radius: 50%; background: #E53E3E; margin-left: 12rpx; }
.notif-content {
  font-size: 26rpx; color: #4B5563; margin-top: 8rpx; line-height: 1.6;
}
.notif-time { font-size: 22rpx; color: #9AA0A6; margin-top: 10rpx; }

.empty { text-align: center; padding: 160rpx 40rpx; }
.empty-emoji { font-size: 90rpx; }
.empty-text { font-size: 30rpx; color: #4B5563; font-weight: 600; margin-top: 24rpx; }
.empty-sub { font-size: 25rpx; color: #9AA0A6; margin-top: 12rpx; }
