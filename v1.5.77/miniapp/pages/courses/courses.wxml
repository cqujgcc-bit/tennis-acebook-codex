<view class="page">
  <view class="banner">
    <view class="banner-title">找专业教练</view>
    <view class="banner-sub">认证教练 · 课时包 · 上完课再扣费</view>
  </view>

  <view class="coach-list">
    <view wx:for="{{coaches}}" wx:key="id" class="coach-card" data-id="{{item.id}}" bindtap="onCoachTap">
      <view class="coach-top">
        <view class="avatar coach-avatar">{{item.name[0]}}</view>
        <view class="coach-main">
          <view class="coach-name-row">
            <text class="coach-name">{{item.name}}</text>
            <text class="coach-rating">⭐ {{item.rating}}</text>
          </view>
          <text class="coach-level">{{item.level}}</text>
          <text class="coach-intro">{{item.intro}}</text>
        </view>
      </view>
      <view class="coach-tags">
        <text wx:for="{{item.tags}}" wx:for-item="t" wx:key="*this" class="tag">{{t}}</text>
      </view>
      <view class="coach-bottom">
        <text class="coach-loc">📍 {{item.locations[0]}}{{item.locations.length > 1 ? ' 等' : ''}}</text>
        <view class="coach-price-wrap">
          <text class="coach-price">¥{{item.pricePerHour}}</text>
          <text class="coach-unit">/课时</text>
        </view>
      </view>
    </view>
  </view>

  <view class="tip">约课为辅助功能，更多教练陆续入驻中</view>
</view>
