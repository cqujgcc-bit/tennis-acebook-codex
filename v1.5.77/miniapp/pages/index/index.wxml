<view class="home">
  <!-- Hero 实拍 -->
  <view class="hero">
    <image class="hero-bg" src="/assets/images/hero-home.jpg" mode="aspectFill"></image>
    <view class="hero-mask"></view>
    <view class="hero-content">
      <view class="hero-brand">AceBook</view>
      <view class="hero-slogan">{{nickname ? 'Hi，' + nickname + '，今天来一局？' : '约球 · 找场地 · 一站式网球生活'}}</view>
    </view>
  </view>

  <!-- 征集中的球局 -->
  <view class="rec-head">
    <text class="rec-title">征集中的球局</text>
    <view class="rec-more" bindtap="goBooking">
      <text>查看全部</text>
      <view class="ab-icon ab-icon-chevron rec-more-icon"></view>
    </view>
  </view>

  <!-- 约球页同款丰富卡片 -->
  <view class="game-list">
    <view
      wx:for="{{recommend}}"
      wx:key="id"
      class="game-card {{item.status === 'full' || item.cdEnded ? 'card-full' : ''}}"
      data-id="{{item.id}}"
      bindtap="goDetail"
    >
      <view class="card-accent"></view>
      <view class="card-body">
        <view class="game-top">
          <view wx:if="{{item.cdText}}" class="countdown {{item.cdClass}}">{{item.cdText}}</view>
          <view wx:else class="countdown-placeholder"></view>
          <view class="game-status {{item.status === 'full' ? 'status-full' : 'status-open'}}">
            {{item.status === 'full' ? '已满员' : '招募中'}}
          </view>
        </view>

        <view class="game-title-wrap">
          <text class="game-title">{{item.title}}</text>
        </view>

        <view wx:if="{{item.isPrivate}}" class="badge-circle">圈 · {{item.circleName}}</view>

        <view class="game-meta">
          <view class="meta-item">
            <text class="meta-emoji">🕒</text>
            <text>{{item.date}} {{item.week}} {{item.startTime}}{{item.endTime ? '-' + item.endTime : ''}}</text>
          </view>
          <view class="meta-item">
            <text class="meta-emoji">📍</text>
            <text>{{item.courtName}}{{item.district ? ' · ' + item.district : ''}}{{item.distanceText}}</text>
          </view>
        </view>

        <view class="game-tags">
          <text class="tag tag-level">🏅 水平 {{item.levelRange}}</text>
          <text wx:for="{{item.tags}}" wx:for-item="t" wx:key="*this" class="tag">{{t}}</text>
        </view>

        <view class="game-bottom">
          <view class="organizer">
            <image wx:if="{{item.organizerAvatar}}" class="avatar avatar-sm avatar-img" src="{{item.organizerAvatar}}" mode="aspectFill"></image>
            <view wx:else class="avatar avatar-sm">{{item.organizerInitial}}</view>
            <text class="org-name">{{item.organizerName}}</text>
          </view>
          <view class="bottom-right">
            <view class="players-pill">
              <text class="players-emoji">👥</text>
              <text>{{item.currentPlayers}}/{{item.maxPlayers}}</text>
            </view>
            <text class="price {{item.isFree ? 'price-free' : ''}}">{{item.priceText}}</text>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{loading}}" class="empty">加载中…</view>
  </view>

  <!-- 空态：当前没有征集中的球局 → 引导用户去做点什么 -->
  <view wx:if="{{!loading && recommend.length === 0}}" class="empty-zone empty-zone-pad">
    <view class="empty-illustration">🎾</view>
    <view class="empty-title">当前还没有征集中的球局</view>
    <view class="empty-sub">不如先发起一局，或去预订一片球场，约上球友打起来！</view>

    <view class="quick-cards">
      <view class="quick-card" bindtap="goCreate">
        <view class="quick-emoji">➕</view>
        <view class="quick-info">
          <view class="quick-name">发布球局</view>
          <view class="quick-desc">设定时间地点，等球友加入</view>
        </view>
      </view>

      <view class="quick-card" bindtap="goVenues">
        <view class="quick-emoji">📍</view>
        <view class="quick-info">
          <view class="quick-name">找球场 · 预订场地</view>
          <view class="quick-desc">i深圳/i深体等 8 个官方平台直达</view>
        </view>
      </view>

      <view class="quick-card" bindtap="goBooking">
        <view class="quick-emoji">🔍</view>
        <view class="quick-info">
          <view class="quick-name">去约球</view>
          <view class="quick-desc">浏览全部球局，加入感兴趣的</view>
        </view>
      </view>

      <view class="quick-card" bindtap="goCircle">
        <view class="quick-emoji">👥</view>
        <view class="quick-info">
          <view class="quick-name">逛圈子</view>
          <view class="quick-desc">加入球友圈，认识更多人</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部安全占位，避免最后一张卡片被悬浮栏遮挡 -->
  <view class="dock-spacer"></view>

  <!-- 底部悬浮双按钮栏（单手拇指区，常驻可点）-->
  <view class="action-dock">
    <view class="dock-btn dock-primary" hover-class="dock-hover" bindtap="goCreate">
      <view class="dock-icon ab-icon-plus-white"></view>
      <text class="dock-text">发起球局</text>
    </view>
    <view class="dock-btn dock-ghost" hover-class="dock-hover" bindtap="goVenues">
      <view class="dock-icon ab-icon-pin-green"></view>
      <text class="dock-text dock-text-dark">找场地</text>
    </view>
  </view>
</view>
