<view class="page">
  <view class="hint">拖动顺序请用「上移/下移」，调整后点「保存顺序」生效。下架的平台用户端不可见。</view>

  <view class="loading-tip" wx:if="{{loading}}">加载中…</view>

  <view class="v-list" wx:else>
    <view class="v-card {{item.enabled ? '' : 'disabled'}}" wx:for="{{list}}" wx:key="id">
      <view class="v-emoji">{{item.emoji || '🎾'}}</view>
      <view class="v-info">
        <view class="v-name">{{item.name}}<text class="off-tag" wx:if="{{!item.enabled}}">已下架</text></view>
        <view class="v-desc">{{item.description || item.appId}}</view>
      </view>
      <view class="v-sort">
        <view class="sort-btn {{index === 0 ? 'dis' : ''}}" bindtap="move" data-idx="{{index}}" data-dir="up">↑</view>
        <view class="sort-btn {{index === list.length - 1 ? 'dis' : ''}}" bindtap="move" data-idx="{{index}}" data-dir="down">↓</view>
      </view>
    </view>
  </view>

  <view class="ops-row" wx:if="{{!loading}}">
    <button class="op-btn ghost" bindtap="onAdd">+ 新增平台</button>
    <button class="op-btn {{dirty ? 'primary' : 'disabled-btn'}}" disabled="{{!dirty}}" bindtap="saveOrder">保存顺序</button>
  </view>

  <view class="manage-list" wx:if="{{!loading}}">
    <view class="section-title">逐个管理</view>
    <view class="m-item" wx:for="{{list}}" wx:key="id">
      <text class="m-name">{{item.emoji}} {{item.name}}</text>
      <view class="m-acts">
        <text class="m-act" bindtap="onEdit" data-item="{{item}}">编辑</text>
        <text class="m-act" bindtap="onToggle" data-item="{{item}}">{{item.enabled ? '下架' : '上架'}}</text>
        <text class="m-act del" bindtap="onDelete" data-item="{{item}}">删除</text>
      </view>
    </view>
  </view>
</view>
