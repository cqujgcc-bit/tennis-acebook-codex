<view class="page">
  <view class="tabs">
    <view wx:for="{{tabs}}" wx:key="key" class="tab {{filter === item.key ? 'active' : ''}}" bindtap="switchTab" data-key="{{item.key}}">{{item.label}}</view>
  </view>

  <view class="loading-tip" wx:if="{{loading}}">加载中…</view>
  <view class="empty" wx:elif="{{list.length === 0}}">暂无反馈</view>

  <view class="fb-list" wx:else>
    <view class="fb-card" wx:for="{{list}}" wx:key="id">
      <view class="fb-top">
        <view class="fb-user">
          <image class="fb-avatar" src="{{item.userAvatar || '/assets/images/default-avatar.png'}}" mode="aspectFill"></image>
          <text class="fb-name">{{item.userName || '用户'}}</text>
        </view>
        <view class="fb-tags">
          <text class="tag cat">{{item.catLabel}}</text>
          <text class="tag status {{item.status}}">{{item.statusLabel}}</text>
        </view>
      </view>
      <view class="fb-content">{{item.content}}</view>
      <view class="fb-meta">
        <text wx:if="{{item.contact}}">联系方式：{{item.contact}}　</text>
        <text>{{item.timeText}}</text>
      </view>
      <view class="fb-reply" wx:if="{{item.adminReply}}">
        <text class="reply-label">官方回复：</text>{{item.adminReply}}
      </view>
      <view class="fb-actions">
        <button class="btn-reply" size="mini" bindtap="onReply" data-id="{{item.id}}">{{item.adminReply ? '再次回复' : '回复'}}</button>
      </view>
    </view>
  </view>
</view>
