page { background: #F4F6F5; }
.page { padding-bottom: 60rpx; }

.header {
  background: linear-gradient(135deg, #0B3D2E 0%, #14503C 100%);
  padding: 36rpx 30rpx 40rpx;
  color: #fff;
}
.user-row { display: flex; align-items: center; }
.avatar-btn-wrap { position: relative; padding: 0; margin: 0; background: transparent; line-height: normal; width: 120rpx; height: 120rpx; }
.avatar-btn-wrap::after { border: none; }
.avatar-img { object-fit: cover; }
.avatar-edit-badge {
  position: absolute; right: -4rpx; bottom: -4rpx;
  width: 40rpx; height: 40rpx; border-radius: 50%;
  background: #D4FF3F; color: #0B3D2E;
  font-size: 28rpx; font-weight: 800;
  display: flex; align-items: center; justify-content: center;
  border: 3rpx solid #0B3D2E;
}
.gender-icon { font-size: 30rpx; margin-left: 12rpx; }
.gender-icon.male { color: #5DA9FF; }
.gender-icon.female { color: #FF8FB1; }
.avatar-lg {
  width: 120rpx; height: 120rpx; font-size: 52rpx; font-weight: 800;
  border-radius: 50%;
  background: rgba(212,255,63,0.18); color: #D4FF3F;
  display: flex; align-items: center; justify-content: center;
}
.user-info { margin-left: 28rpx; flex: 1; }
.nickname { font-size: 38rpx; font-weight: 700; }
.user-sub { font-size: 26rpx; opacity: 0.92; margin-top: 8rpx; }
.user-bio { font-size: 24rpx; opacity: 0.78; margin-top: 8rpx; }

.stats {
  display: flex; margin-top: 36rpx;
  background: rgba(255,255,255,0.12);
  border-radius: 20rpx; padding: 26rpx 0;
}
.stat-item { flex: 1; display: flex; flex-direction: column; align-items: center; }
.stat-num { font-size: 42rpx; font-weight: 800; color: #D4FF3F; }
.stat-label { font-size: 24rpx; opacity: 0.85; margin-top: 6rpx; }

.menu-group {
  background: #fff; margin: 24rpx 32rpx 0; border-radius: 24rpx; overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}
.menu-item {
  display: flex; align-items: center;
  padding: 32rpx 28rpx; border-bottom: 1rpx solid #F2F4F3;
}
.menu-item:last-child { border-bottom: none; }
.menu-ico { font-size: 36rpx; margin-right: 24rpx; }
.menu-text { flex: 1; font-size: 30rpx; color: #1F2937; }
.menu-val { font-size: 28rpx; color: #0B3D2E; font-weight: 700; margin-right: 12rpx; }
.menu-tip { font-size: 22rpx; color: #0B3D2E; margin-right: 12rpx; }
.menu-arrow { color: #C7CDC9; font-size: 36rpx; }
.menu-badge { min-width: 32rpx; height: 32rpx; padding: 0 10rpx; border-radius: 16rpx; background: #E53E3E; color: #fff; font-size: 20rpx; line-height: 32rpx; text-align: center; margin-right: 12rpx; box-sizing: border-box; }

.logout {
  margin: 40rpx 32rpx; text-align: center; padding: 30rpx;
  background: #fff; border-radius: 24rpx;
  color: #E85C5C; font-size: 30rpx; font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

/* ============================================================
   v1.5.28 UI 运动风尚升级
   个人页：仪表盘感增强、菜单项动画
   ============================================================ */

/* —— 统计数据区增强 —— */
.stats {
  transition: transform 0.15s ease;
}
.stats:active {
  transform: scale(0.98);
}

/* —— 统计数字微动 —— */
.stat-num {
  transition: color 0.2s ease;
}
.stat-item:active .stat-num {
  color: #fff;
}

/* —— 菜单项反馈 —— */
.menu-item {
  transition: background 0.15s ease, padding-left 0.15s ease;
}
.menu-item:active {
  background: #F5F8F6;
  padding-left: 34rpx;
}

/* —— 用户资料区体验优化 —— */
.user-info:active {
  opacity: 0.78;
}

/* —— 登出按钮增强 —— */
.logout {
  transition: all 0.2s ease;
}
.logout:active {
  transform: scale(0.97);
  background: #FFF5F5;
}

/* —— 邀请码加入增强（和圈子页一致）—— */
.menu-group {
  animation: ab-card-enter 0.45s ease-out both;
}
.menu-group:nth-child(2) { animation-delay: 0.08s; }
.menu-group:nth-child(3) { animation-delay: 0.16s; }
.menu-group:nth-child(4) { animation-delay: 0.24s; }
.menu-group:nth-child(5) { animation-delay: 0.32s; }

/* —— 退出按钮动画 —— */
.logout {
  animation: ab-card-enter 0.4s ease-out 0.3s both;
}
