<view class="page">
  <!-- 顶部标题区 -->
  <view class="page-head">
    <view class="head-deco"></view>
    <view class="head-title">我的圈子</view>
    <view class="head-sub">网球，和熟悉的人一起打更尽兴</view>
  </view>

  <!-- 邀请码加入 -->
  <view class="join-card">
    <view class="join-icon">🔑</view>
    <input class="join-input" placeholder="输入邀请码加入圈子" placeholder-class="join-ph" value="{{inviteCode}}" bindinput="onCodeInput" confirm-type="done" bindconfirm="onJoinByCode" />
    <view class="join-btn" bindtap="onJoinByCode">加入</view>
  </view>

  <view wx:if="{{loading}}" class="state-tip">加载中…</view>

  <!-- 空态 -->
  <view wx:elif="{{list.length === 0}}" class="empty-box">
    <view class="empty-emoji">🎾</view>
    <view class="empty-title">你还没有加入任何圈子</view>
    <view class="empty-desc">圈子是被球友拉进来的小天地。\n向相熟的球友要一个邀请码，或自己创建一个圈子吧。</view>
    <view class="empty-btn" bindtap="onCreateCircle">+ 创建我的圈子</view>
  </view>

  <!-- 圈子列表 -->
  <view wx:else class="circle-list">
    <view wx:for="{{list}}" wx:key="id" class="circle-card" data-id="{{item.id}}" data-code="{{item.inviteCode}}" bindtap="goDetail">
      <!-- 左侧色带 -->
      <view class="card-accent"></view>

      <view class="card-top">
        <view class="circle-avatar">{{item.name[0]}}</view>
        <view class="circle-info">
          <view class="circle-name-row">
            <text class="circle-name">{{item.name}}</text>
            <text class="role-tag {{item.isOwner ? 'role-owner' : 'role-member'}}">{{item.roleLabel}}</text>
          </view>
          <text class="circle-desc">{{item.description}}</text>
        </view>
        <!-- 卡片右上角更多菜单：成员可退出、圈主可进管理 -->
        <view class="card-more" catchtap="onOpenCardMenu" data-index="{{index}}">
          <view class="dot"></view><view class="dot"></view><view class="dot"></view>
        </view>
      </view>

      <view class="card-bottom">
        <view class="avatar-wall">
          <block wx:for="{{item.avatars}}" wx:for-item="m" wx:key="index">
            <image wx:if="{{m.avatar}}" class="wall-avatar" src="{{m.avatar}}" mode="aspectFill" />
            <view wx:else class="wall-avatar wall-letter">{{m.letter}}</view>
          </block>
          <view wx:if="{{item.extraCount > 0}}" class="wall-avatar wall-extra">+{{item.extraCount}}</view>
        </view>
        <view class="card-stats">
          <text class="stat-chip">👥 {{item.memberCount}}人</text>
          <text wx:if="{{item.activeGames > 0}}" class="stat-chip stat-active">🔥 {{item.activeGames}}征集中</text>
          <text wx:else class="stat-chip stat-idle">暂无球局</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{!loading && list.length > 0}}" class="create-circle" bindtap="onCreateCircle">
    <text class="create-plus">+</text> 创建新圈子
  </view>

  <!-- 卡片操作菜单（底部弹出） -->
  <view wx:if="{{showMenu}}" class="menu-mask" bindtap="closeCardMenu">
    <view class="menu-sheet" catchtap="noop">
      <view class="menu-head">
        <text class="menu-head-name">{{menuCircle.name}}</text>
        <text class="menu-head-role">{{menuCircle.roleLabel}}</text>
      </view>
      <view class="menu-item" bindtap="onEnterFromMenu">
        <text class="menu-item-icon">👀</text>进入圈子
      </view>
      <view wx:if="{{menuCircle.isOwner}}" class="menu-item" bindtap="onManageFromMenu">
        <text class="menu-item-icon">⚙️</text>圈子管理
      </view>
      <view wx:else class="menu-item danger" bindtap="onLeaveFromMenu">
        <text class="menu-item-icon">🚪</text>退出圈子
      </view>
      <view class="menu-cancel" bindtap="closeCardMenu">取消</view>
    </view>
  </view>
</view>
