.about { min-height: 100vh; background: #F4F6F5; padding-bottom: 60rpx; }

.hero {
  background: linear-gradient(160deg, #0E4A36 0%, #0B3D2E 60%, #093526 100%);
  padding: 70rpx 40rpx 64rpx; text-align: center; color: #fff;
}
.hero .logo { font-size: 96rpx; line-height: 1; }
.hero .brand { font-size: 56rpx; font-weight: 800; letter-spacing: 2rpx; margin-top: 16rpx; }
.hero .slogan { font-size: 26rpx; color: #D4FF3F; margin-top: 16rpx; }
.hero .ver { font-size: 22rpx; color: rgba(255,255,255,0.6); margin-top: 20rpx; }

.card {
  margin: 24rpx 24rpx 0; background: #fff; border-radius: 24rpx;
  padding: 32rpx 32rpx 36rpx; box-shadow: 0 4rpx 16rpx rgba(11,61,46,0.04);
}
.card-title {
  font-size: 32rpx; font-weight: 700; color: #0B3D2E; margin-bottom: 20rpx;
  padding-left: 20rpx; border-left: 8rpx solid #D4FF3F; line-height: 1.1;
}
.para { font-size: 28rpx; color: #3A4A43; line-height: 1.75; margin-bottom: 16rpx; }
.para:last-child { margin-bottom: 0; }

.feat { display: flex; align-items: flex-start; padding: 20rpx 0; border-bottom: 1rpx solid #F0F2F1; }
.feat:last-child { border-bottom: none; padding-bottom: 0; }
.feat-ico { font-size: 44rpx; width: 64rpx; flex-shrink: 0; line-height: 1.2; }
.feat-body { flex: 1; }
.feat-name { font-size: 30rpx; font-weight: 700; color: #1F2937; margin-bottom: 8rpx; }
.feat-desc { font-size: 25rpx; color: #6B7C74; line-height: 1.65; }

.info-row { display: flex; padding: 16rpx 0; border-bottom: 1rpx solid #F0F2F1; }
.info-row:last-child { border-bottom: none; }
.info-k { width: 160rpx; flex-shrink: 0; font-size: 27rpx; color: #9AA8A1; }
.info-v { flex: 1; font-size: 27rpx; color: #1F2937; }

.btn {
  margin-top: 24rpx; background: #0B3D2E; color: #D4FF3F; text-align: center;
  font-size: 29rpx; font-weight: 600; padding: 26rpx 0; border-radius: 16rpx;
}

.copyright {
  margin: 48rpx 40rpx 0; text-align: center; font-size: 22rpx;
  color: #AEB8B3; line-height: 1.7; white-space: pre-line;
}
