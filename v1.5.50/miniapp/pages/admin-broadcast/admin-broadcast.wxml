<view class="page">
  <view class="card">
    <view class="field">
      <text class="label">公告标题</text>
      <input class="input" placeholder="如：系统维护通知" value="{{title}}" maxlength="50" bindinput="onTitle" />
    </view>
    <view class="field">
      <text class="label">公告内容</text>
      <textarea class="textarea" placeholder="请输入公告正文，将以系统通知形式推送给用户" value="{{content}}" maxlength="1000" bindinput="onContent" />
      <text class="count">{{content.length}}/1000</text>
    </view>
    <view class="field">
      <text class="label">发送范围</text>
      <picker mode="selector" range="{{scopes}}" range-key="label" value="{{scopeIndex}}" bindchange="onScope">
        <view class="picker">{{scopes[scopeIndex].label}} ›</view>
      </picker>
    </view>
  </view>

  <button class="submit-btn" loading="{{submitting}}" bindtap="onSubmit">发送公告</button>
  <view class="tip">公告将作为「系统通知」进入用户的消息中心，请确保内容准确。</view>
</view>
