.admin-page { min-height: 100vh; background: #f4f6f5; padding-bottom: 60rpx; }
.hd { background: linear-gradient(135deg, #0E4A36, #093526); padding: 36rpx 30rpx 40rpx; color: #fff; }
.hd-title { font-size: 44rpx; font-weight: 700; }
.hd-sub { font-size: 24rpx; opacity: 0.8; margin-top: 8rpx; }

.section-title { font-size: 28rpx; color: #555; font-weight: 600; margin: 36rpx 32rpx 18rpx; }

.stat-grid { display: flex; flex-wrap: wrap; padding: 0 22rpx; }
.stat-card { width: calc(33.33% - 20rpx); margin: 10rpx; background: #fff; border-radius: 24rpx; padding: 30rpx 10rpx; text-align: center; box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.04); }
.stat-num { font-size: 44rpx; font-weight: 700; color: #0B3D2E; }
.stat-label { font-size: 22rpx; color: #888; margin-top: 8rpx; }
.loading-tip { text-align: center; color: #999; font-size: 26rpx; padding: 30rpx; }

.menu-list { margin: 0 32rpx; background: #fff; border-radius: 24rpx; overflow: hidden; }
.menu-item { display: flex; align-items: center; justify-content: space-between; padding: 34rpx 30rpx; border-bottom: 1rpx solid #f0f0f0; }
.menu-item:last-child { border-bottom: none; }
.mi-left { display: flex; align-items: center; }
.mi-emoji { font-size: 36rpx; margin-right: 20rpx; }
.mi-name { font-size: 30rpx; color: #222; }
.mi-right { display: flex; align-items: center; }
.badge { background: #ff4d4f; color: #fff; font-size: 22rpx; border-radius: 20rpx; padding: 2rpx 14rpx; margin-right: 14rpx; }
.arrow { color: #ccc; font-size: 40rpx; }

.footer-tip { text-align: center; color: #aaa; font-size: 22rpx; margin-top: 40rpx; }
