<view class="page">
  <view wx:if="{{loading}}" class="state">加载中...</view>

  <!-- 可接位 -->
  <block wx:elif="{{status === 'pending' && match}}">
    <view class="hero">
      <view class="hero-tip">球友邀你顶上空位</view>
      <view class="hero-title">{{match.title}}</view>
      <view wx:if="{{fromUser}}" class="hero-from">来自 {{fromUser.name}} 的接位邀请</view>
    </view>

    <view class="card">
      <view class="row"><text class="k">时间</text><text class="v">{{match.date}} {{match.startTime}}{{match.endTime ? '-' + match.endTime : ''}}</text></view>
      <view class="row"><text class="k">球场</text><text class="v">{{match.courtName}}</text></view>
      <view wx:if="{{match.district}}" class="row"><text class="k">地址</text><text class="v">{{match.district}}</text></view>
      <view class="row"><text class="k">水平</text><text class="v">{{match.levelRange}}</text></view>
      <view class="row"><text class="k">费用</text><text class="v price">{{match.feeRequired ? '¥' + match.feePerPerson + '/人' : '免费'}}</text></view>
    </view>

    <view class="note">接位后您将顶替对方的位置加入本局{{match.feeRequired ? '，需在线支付场地费' : ''}}。对方将获得全额退款且不扣信用分。</view>

    <view class="bottom">
      <button class="btn" loading="{{accepting || paying}}" bindtap="onAccept">{{match.feeRequired ? '接位并支付 ¥' + match.feePerPerson : '确认接位'}}</button>
    </view>
  </block>

  <!-- 已被接受 -->
  <view wx:elif="{{status === 'accepted'}}" class="state">
    <view class="state-icon">✓</view>
    <view class="state-title">该位置已被接走</view>
    <view class="state-sub">手慢了一步，下次更快哦</view>
  </view>

  <!-- 过期/无效 -->
  <view wx:else class="state">
    <view class="state-icon">⏰</view>
    <view class="state-title">邀请已失效</view>
    <view class="state-sub">链接已过期或球局已开始</view>
  </view>
</view>
