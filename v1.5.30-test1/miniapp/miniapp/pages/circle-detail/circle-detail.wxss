page { background: #F4F6F5; }
.page { padding-bottom: 160rpx; }

/* 头部 */
.hero {
  background: linear-gradient(135deg, #0B3D2E 0%, #093526 100%);
  padding: 40rpx 32rpx 32rpx;
}
.hero-top { display: flex; align-items: center; }
.circle-avatar-lg {
  width: 120rpx; height: 120rpx; border-radius: 28rpx;
  background: rgba(212,255,63,0.15); color: #D4FF3F;
  display: flex; align-items: center; justify-content: center;
  font-size: 56rpx; font-weight: 800; flex-shrink: 0;
}
.hero-main { flex: 1; margin-left: 24rpx; min-width: 0; }
.hero-name { font-size: 38rpx; font-weight: 800; color: #fff; }
.hero-desc {
  font-size: 25rpx; color: rgba(255,255,255,0.7); margin-top: 8rpx;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.hero-stats { display: flex; margin-top: 16rpx; font-size: 25rpx; color: rgba(255,255,255,0.9); }
.stat-gap { margin-left: 28rpx; }
.invite-row {
  display: flex; align-items: center; margin-top: 26rpx;
  background: rgba(255,255,255,0.1); border-radius: 16rpx; padding: 18rpx 24rpx;
}
.invite-label { font-size: 25rpx; color: rgba(255,255,255,0.85); }
.invite-code { flex: 1; margin-left: 16rpx; font-size: 30rpx; font-weight: 800; color: #D4FF3F; letter-spacing: 2rpx; }
.invite-copy { font-size: 23rpx; color: rgba(255,255,255,0.6); }

/* Tabs */
.tabs {
  display: flex; background: #fff;
  position: sticky; top: 0; z-index: 5;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.04);
}
.tab {
  flex: 1; text-align: center; padding: 26rpx 0;
  font-size: 28rpx; color: #6B7280; position: relative;
}
.tab.active { color: #0B3D2E; font-weight: 700; }
.tab.active::after {
  content: ''; position: absolute; bottom: 0; left: 50%; transform: translateX(-50%);
  width: 56rpx; height: 6rpx; border-radius: 6rpx; background: #0B3D2E;
}

.tab-body { padding: 24rpx 32rpx; }
.empty-tip { text-align: center; color: #9AA0A6; font-size: 26rpx; padding: 70rpx 30rpx; line-height: 1.7; }

/* 发动态 */
.post-trigger {
  background: #fff; border-radius: 20rpx; padding: 28rpx;
  margin-bottom: 24rpx; box-shadow: 0 4rpx 14rpx rgba(0,0,0,0.04);
}
.post-trigger-text { font-size: 28rpx; color: #0B3D2E; font-weight: 600; }
.post-box { background: #fff; border-radius: 20rpx; padding: 24rpx; margin-bottom: 24rpx; box-shadow: 0 4rpx 14rpx rgba(0,0,0,0.04); }
.post-textarea { width: 100%; min-height: 140rpx; font-size: 28rpx; line-height: 1.6; }
.post-actions { display: flex; justify-content: flex-end; align-items: center; margin-top: 16rpx; }
.post-cancel { font-size: 27rpx; color: #6B7280; padding: 12rpx 32rpx; }
.post-submit { font-size: 27rpx; color: #D4FF3F; font-weight: 700; background: #0B3D2E; padding: 14rpx 40rpx; border-radius: 999rpx; }
.post-submit.disabled { opacity: 0.5; }

/* 动态卡片 */
.post-card { background: #fff; border-radius: 20rpx; padding: 28rpx; margin-bottom: 20rpx; box-shadow: 0 4rpx 14rpx rgba(0,0,0,0.04); }
.post-head { display: flex; align-items: center; }
.post-avatar { width: 70rpx; height: 70rpx; border-radius: 50%; flex-shrink: 0; }
.post-letter { background: linear-gradient(135deg,#14503C,#0B3D2E); color: #D4FF3F; display: flex; align-items: center; justify-content: center; font-size: 30rpx; font-weight: 700; }
.post-meta { margin-left: 18rpx; flex: 1; min-width: 0; }
.post-del { flex-shrink: 0; font-size: 24rpx; color: #9AA0A6; padding: 6rpx 16rpx; border: 1rpx solid #E5E7EB; border-radius: 999rpx; }
.post-author { font-size: 28rpx; font-weight: 700; color: #1A1A1A; }
.pin-tag { font-size: 19rpx; color: #C2410C; background: #FFF1E8; padding: 2rpx 12rpx; border-radius: 999rpx; margin-left: 12rpx; font-weight: 600; }
.post-time { font-size: 23rpx; color: #9AA0A6; margin-top: 4rpx; }
.post-content { font-size: 29rpx; color: #2A2A2A; line-height: 1.7; margin-top: 18rpx; white-space: pre-wrap; }
.post-foot { display: flex; justify-content: flex-end; margin-top: 16rpx; }
.like-btn { font-size: 26rpx; color: #6B7280; padding: 8rpx 24rpx; background: #F4F6F5; border-radius: 999rpx; }
.like-btn.liked { color: #C2410C; }

/* 球局卡片 */
.match-card { background: #fff; border-radius: 20rpx; padding: 28rpx; margin-bottom: 20rpx; box-shadow: 0 4rpx 14rpx rgba(0,0,0,0.04); }
.match-top { display: flex; align-items: center; justify-content: space-between; }
.match-title { font-size: 30rpx; font-weight: 700; color: #1A1A1A; flex: 1; }
.match-status { font-size: 22rpx; padding: 6rpx 18rpx; border-radius: 999rpx; font-weight: 600; }
.st-active { background: #0B3D2E; color: #D4FF3F; }
.st-idle { background: #EEF0EF; color: #9AA0A6; }
.match-line { font-size: 26rpx; color: #4B5563; margin-top: 14rpx; }
.match-foot { display: flex; align-items: center; margin-top: 16rpx; padding-top: 16rpx; border-top: 2rpx solid #F0F2F1; }
.match-level { font-size: 24rpx; color: #0B3D2E; background: #EAF3ED; padding: 6rpx 16rpx; border-radius: 999rpx; }
.match-people { font-size: 25rpx; color: #4B5563; margin-left: auto; }

/* 排行榜 */
.rank-head { font-size: 23rpx; color: #9AA0A6; padding: 4rpx 8rpx 20rpx; }
.rank-row { display: flex; align-items: center; background: #fff; border-radius: 18rpx; padding: 22rpx 24rpx; margin-bottom: 16rpx; box-shadow: 0 4rpx 14rpx rgba(0,0,0,0.04); }
.rank-num { width: 50rpx; text-align: center; font-size: 30rpx; font-weight: 800; color: #9AA0A6; flex-shrink: 0; }
.rank-num.rank-1 { color: #E0A800; }
.rank-num.rank-2 { color: #9CA3AF; }
.rank-num.rank-3 { color: #C97B3F; }
.rank-avatar { width: 64rpx; height: 64rpx; border-radius: 50%; margin: 0 20rpx; flex-shrink: 0; }
.rank-letter { background: linear-gradient(135deg,#14503C,#0B3D2E); color: #D4FF3F; display: flex; align-items: center; justify-content: center; font-size: 28rpx; font-weight: 700; }
.rank-name { font-size: 29rpx; font-weight: 600; color: #1A1A1A; flex: 1; }
.rank-role { font-size: 21rpx; color: #0B3D2E; background: #EAF3ED; padding: 4rpx 14rpx; border-radius: 999rpx; margin-right: 16rpx; }
.rank-points { font-size: 27rpx; font-weight: 700; color: #0B3D2E; flex-shrink: 0; }

/* 底栏 */
.bottom-spacer { height: 20rpx; }
.bottom-bar {
  position: fixed; left: 0; right: 0; bottom: 0;
  padding: 18rpx 32rpx calc(18rpx + env(safe-area-inset-bottom));
  background: #fff; box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.06);
  display: flex; gap: 18rpx;
}
.bar-btn {
  flex: 1;
  background: linear-gradient(135deg,#0B3D2E,#14503C); color: #D4FF3F;
  border-radius: 999rpx; font-size: 30rpx; font-weight: 700;
  height: 88rpx; line-height: 1; padding: 0;
  display: flex; align-items: center; justify-content: center;
}
.bar-btn-ghost {
  flex: 0 0 34%;
  background: #F2F4F3; color: #0B3D2E;
}
.bar-btn::after { border: none; }

/* ─── 动态评论 ─── */
.post-foot { display: flex; justify-content: flex-end; align-items: center; gap: 16rpx; margin-top: 16rpx; }
.cmt-btn { font-size: 26rpx; color: #6B7280; padding: 8rpx 24rpx; background: #F4F6F5; border-radius: 999rpx; }
.comment-list { margin-top: 18rpx; padding-top: 16rpx; border-top: 2rpx solid #F0F2F1; }
.comment-item { display: flex; margin-bottom: 18rpx; }
.cmt-avatar { width: 52rpx; height: 52rpx; border-radius: 50%; flex-shrink: 0; }
.cmt-letter { background: linear-gradient(135deg,#14503C,#0B3D2E); color: #D4FF3F; display: flex; align-items: center; justify-content: center; font-size: 24rpx; font-weight: 700; }
.cmt-body { margin-left: 16rpx; flex: 1; min-width: 0; }
.cmt-author { font-size: 25rpx; font-weight: 600; color: #0B3D2E; }
.cmt-reply-to { color: #9AA0A6; font-weight: 400; }
.cmt-text { font-size: 27rpx; color: #2A2A2A; line-height: 1.6; margin-top: 4rpx; white-space: pre-wrap; }
.cmt-meta { display: flex; align-items: center; margin-top: 6rpx; }
.cmt-time { font-size: 22rpx; color: #9AA0A6; }
.cmt-reply { font-size: 22rpx; color: #0B3D2E; margin-left: 20rpx; }
.cmt-empty { font-size: 24rpx; color: #9AA0A6; padding: 8rpx 0 12rpx; }
.cmt-input-row { display: flex; align-items: center; margin-top: 12rpx; gap: 14rpx; }
.cmt-input { flex: 1; box-sizing: border-box; background: #F4F6F5; border-radius: 999rpx; padding: 0 24rpx; font-size: 26rpx; height: 64rpx; line-height: 64rpx; }
.cmt-send { font-size: 25rpx; color: #D4FF3F; font-weight: 700; background: #0B3D2E; padding: 12rpx 30rpx; border-radius: 999rpx; flex-shrink: 0; }
.cmt-send.disabled { opacity: 0.5; }

/* ─── 圈主设置入口 ─── */
.hero-gear { position: absolute; top: 36rpx; right: 32rpx; width: 64rpx; height: 64rpx; border-radius: 50%; background: rgba(255,255,255,0.12); display: flex; align-items: center; justify-content: center; font-size: 34rpx; }
.hero { position: relative; }

/* 设置弹窗 */
.modal-mask { position: fixed; inset: 0; background: rgba(0,0,0,0.45); z-index: 100; display: flex; align-items: flex-end; }
.modal-sheet { width: 100%; background: #fff; border-radius: 28rpx 28rpx 0 0; padding: 36rpx 32rpx calc(36rpx + env(safe-area-inset-bottom)); }
.modal-title { font-size: 32rpx; font-weight: 800; color: #1A1A1A; text-align: center; margin-bottom: 28rpx; }
.modal-item { font-size: 29rpx; color: #1A1A1A; padding: 28rpx 8rpx; border-bottom: 2rpx solid #F0F2F1; display: flex; align-items: center; }
.modal-item.danger { color: #C2410C; }
.modal-item-icon { margin-right: 16rpx; font-size: 32rpx; }
.req-badge { margin-left: auto; min-width: 36rpx; height: 36rpx; line-height: 36rpx; text-align: center; background: #E5392E; color: #fff; font-size: 22rpx; border-radius: 18rpx; padding: 0 10rpx; }

/* 入圈申请审核列表 */
.req-list { max-height: 60vh; overflow-y: auto; }
.req-row { display: flex; align-items: center; padding: 22rpx 4rpx; border-bottom: 2rpx solid #F0F2F1; }
.req-avatar { width: 80rpx; height: 80rpx; border-radius: 50%; flex-shrink: 0; }
.req-letter { background: #DCE7E1; color: #0B3D2E; display: flex; align-items: center; justify-content: center; font-size: 34rpx; font-weight: 700; }
.req-info { flex: 1; display: flex; flex-direction: column; margin-left: 20rpx; min-width: 0; }
.req-name { font-size: 28rpx; color: #1A1A1A; font-weight: 600; }
.req-level { font-size: 22rpx; color: #0B3D2E; margin-top: 4rpx; }
.req-msg { font-size: 23rpx; color: #6B7C72; margin-top: 4rpx; }
.req-actions { display: flex; gap: 14rpx; flex-shrink: 0; }
.req-btn { padding: 12rpx 26rpx; font-size: 26rpx; font-weight: 600; border-radius: 30rpx; }
.req-btn.approve { background: #0B3D2E; color: #D4FF3F; }
.req-btn.reject { background: #F4F6F5; color: #6B7280; }
.req-btn:active { opacity: 0.85; }
.modal-cancel { margin-top: 24rpx; text-align: center; font-size: 29rpx; color: #6B7280; padding: 26rpx; background: #F4F6F5; border-radius: 16rpx; }

/* 编辑说明弹窗 */
.edit-box { background: #fff; border-radius: 24rpx; padding: 36rpx 32rpx; width: 100%; }
.edit-label { font-size: 28rpx; font-weight: 700; color: #1A1A1A; margin-bottom: 18rpx; }
.edit-textarea { width: 100%; min-height: 160rpx; background: #F4F6F5; border-radius: 16rpx; padding: 22rpx; font-size: 28rpx; line-height: 1.6; box-sizing: border-box; }
.edit-actions { display: flex; gap: 20rpx; margin-top: 28rpx; }
.edit-btn { flex: 1; text-align: center; padding: 26rpx; border-radius: 16rpx; font-size: 29rpx; font-weight: 700; }
.edit-btn.cancel { background: #F4F6F5; color: #6B7280; }
.edit-btn.confirm { background: #0B3D2E; color: #D4FF3F; }
.modal-center { align-items: center; padding: 0 48rpx; }

/* 转让成员选择 */
.member-pick { max-height: 60vh; overflow-y: auto; }
.member-row { display: flex; align-items: center; padding: 22rpx 8rpx; border-bottom: 2rpx solid #F0F2F1; }
.member-avatar { width: 64rpx; height: 64rpx; border-radius: 50%; flex-shrink: 0; }
.member-letter { background: linear-gradient(135deg,#14503C,#0B3D2E); color: #D4FF3F; display: flex; align-items: center; justify-content: center; font-size: 28rpx; font-weight: 700; }
.member-name { font-size: 29rpx; color: #1A1A1A; margin-left: 18rpx; flex: 1; }
.member-go { font-size: 25rpx; color: #0B3D2E; }
