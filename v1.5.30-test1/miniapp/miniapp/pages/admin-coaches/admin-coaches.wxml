<view class="page">
  <view class="loading-tip" wx:if="{{loading}}">加载中…</view>
  <view class="empty" wx:elif="{{list.length === 0}}">
    <text class="empty-emoji">✅</text>
    <text>暂无待审核教练</text>
  </view>

  <view class="c-list" wx:else>
    <view class="c-card" wx:for="{{list}}" wx:key="id">
      <view class="c-top">
        <image class="c-avatar" src="{{item.avatar || '/assets/images/default-avatar.png'}}" mode="aspectFill"></image>
        <view class="c-head">
          <view class="c-name">{{item.displayName}}</view>
          <view class="c-tagline">{{item.tagline || '—'}}</view>
        </view>
      </view>
      <view class="c-row"><text class="c-k">执教年限</text><text class="c-v">{{item.yearsExperience || 0}} 年</text></view>
      <view class="c-row"><text class="c-k">联系电话</text><text class="c-v">{{item.phone || '未填写'}}</text></view>
      <view class="c-row"><text class="c-k">专长</text><text class="c-v">{{item.specs}}</text></view>
      <view class="c-row"><text class="c-k">资质证书</text><text class="c-v">{{item.certs}}</text></view>
      <view class="c-bio" wx:if="{{item.bio}}">{{item.bio}}</view>

      <view class="c-imgs" wx:if="{{item.certImgs.length > 0}}">
        <image wx:for="{{item.certImgs}}" wx:for-item="img" wx:key="*this" class="cert-img" src="{{img}}" mode="aspectFill" bindtap="previewImg" data-url="{{img}}" data-urls="{{item.certImgs}}"></image>
      </view>

      <view class="c-actions">
        <button class="btn reject" size="mini" bindtap="onReject" data-id="{{item.id}}">驳回</button>
        <button class="btn approve" size="mini" bindtap="onApprove" data-id="{{item.id}}">通过</button>
      </view>
    </view>
  </view>
</view>
